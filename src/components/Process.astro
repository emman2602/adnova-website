---
const steps = [
  {
    number: '01',
    title: 'Diagnóstico',
    description:
      'Entendemos tus objetivos, procesos actuales, puntos de dolor y oportunidades de mejora.',
    className: 'muted'
  },
  {
    number: '02',
    title: 'Arquitectura',
    description:
      'Diseñamos módulos, flujos, alcance, tecnología, prioridades y un plan de trabajo claro.',
    className: 'blue'
  },
  {
    number: '03',
    title: 'Desarrollo',
    description:
      'Construimos por etapas, validamos avances contigo y entregamos funcionalidades reales.',
    className: 'dark-blue'
  },
  {
    number: '04',
    title: 'Crecimiento',
    description:
      'Implementamos, damos soporte, medimos resultados y evolucionamos el sistema contigo.',
    className: 'black'
  }
];
---

<section id="proceso" class="process-section source-container">
  <div class="process-sticky">
    <div class="process-heading">
      <h2>Cómo convertimos ideas en sistemas funcionales.</h2>

      <p>
        ADNOVA te guía mediante un proceso claro que combina análisis,
        precisión técnica y entregas funcionales desde las primeras etapas.
      </p>
    </div>

    <div class="process-cards" id="process-cards">
      {steps.map((step, index) => (
        <article
          class={`process-card ${step.className}`}
          data-step={index}
        >
          <div class="card-top">
            <span>{step.number}</span>
            <h3>{step.title}</h3>
          </div>

          <p>{step.description}</p>

          <strong>{step.number}</strong>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .process-section {
    position: relative;
    height: 280vh;
    padding: 0;
    overflow: visible;
  }

  .process-sticky {
    position: sticky;
    top: 64px;
    min-height: calc(100vh - 64px);
    padding: 54px 34px 34px;
    overflow: hidden;
    border-left: 1px solid var(--line);
    border-right: 1px solid var(--line);
    background: var(--bg);
  }

  .process-heading {
    display: grid;
    grid-template-columns: 1fr 0.48fr;
    gap: 90px;
    margin-bottom: 46px;
  }

  .process-heading h2 {
    max-width: 900px;
    margin: 0;
    color: var(--ink);
    font-size: clamp(40px, 4.5vw, 82px);
    line-height: 0.98;
    font-weight: 620;
    letter-spacing: -0.065em;
  }

  .process-heading p {
    max-width: 560px;
    margin: 0;
    color: var(--muted);
    font-size: clamp(17px, 1.45vw, 22px);
    line-height: 1.38;
    font-weight: 440;
    letter-spacing: -0.025em;
  }

  .process-cards {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 4px;
    align-items: end;
  }

  .process-card {
    position: relative;
    min-height: 430px;
    padding: 32px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: space-between;

    opacity: 0;
    transform: translateY(120px) scale(0.96);
    transition:
      opacity 0.75s cubic-bezier(.16, 1, .3, 1),
      transform 0.75s cubic-bezier(.16, 1, .3, 1),
      filter 0.35s ease;
    will-change: opacity, transform;
  }

  .process-card.is-visible {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .process-card:hover {
    filter: contrast(1.04);
  }

  .card-top {
    position: relative;
    z-index: 2;
  }

  .card-top span {
    display: block;
    margin-bottom: 10px;
    color: currentColor;
    font-size: clamp(36px, 3.5vw, 60px);
    line-height: 1;
    font-weight: 620;
    letter-spacing: -0.065em;
  }

  .card-top h3 {
    margin: 0;
    color: currentColor;
    font-size: clamp(28px, 2.6vw, 44px);
    line-height: 1;
    font-weight: 620;
    letter-spacing: -0.06em;
  }

  .process-card p {
    position: relative;
    z-index: 2;
    max-width: 320px;
    margin: 0;
    color: currentColor;
    font-size: clamp(17px, 1.35vw, 21px);
    line-height: 1.35;
    font-weight: 440;
    letter-spacing: -0.025em;
  }

  .process-card strong {
    position: absolute;
    top: -20px;
    right: -18px;
    z-index: 1;
    color: rgba(23, 19, 15, 0.07);
    font-size: clamp(130px, 12vw, 230px);
    line-height: 1;
    font-weight: 800;
    letter-spacing: -0.1em;
    pointer-events: none;
  }

  .process-card.muted {
    background: var(--panel);
    color: var(--ink);
  }

  .process-card.blue {
    background: var(--blue);
    color: white;
  }

  .process-card.dark-blue {
    background: var(--blue-dark);
    color: white;
  }

  .process-card.black {
    background: var(--black);
    color: white;
  }

  .process-card.blue strong,
  .process-card.dark-blue strong,
  .process-card.black strong {
    color: rgba(255, 255, 255, 0.08);
  }

  @media (max-width: 1200px) {
    .process-section {
      height: auto;
      padding: 82px 0;
    }

    .process-sticky {
      position: relative;
      top: auto;
      min-height: auto;
    }

    .process-heading {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    .process-cards {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      align-items: stretch;
    }

    .process-card {
      min-height: 360px;
      opacity: 1;
      transform: none;
    }
  }

  @media (max-width: 700px) {
    .process-section {
      padding: 70px 0;
    }

    .process-sticky {
      padding: 44px 20px 20px;
      border-left: 0;
      border-right: 0;
    }

    .process-heading h2 {
      font-size: clamp(36px, 10vw, 56px);
    }

    .process-cards {
      grid-template-columns: 1fr;
    }

    .process-card {
      min-height: 320px;
      padding: 28px;
    }

    .process-card p {
      font-size: 17px;
    }
  }
</style>

<script>
  const processSection = document.querySelector<HTMLElement>('.process-section');
  const processCards = Array.from(
    document.querySelectorAll<HTMLElement>('.process-card')
  );

  const updateProcessCards = () => {
    if (!processSection || processCards.length === 0) return;

    const rect = processSection.getBoundingClientRect();
    const viewportHeight = window.innerHeight;

    const totalScrollable = rect.height - viewportHeight;
    const scrolled = Math.min(Math.max(-rect.top, 0), totalScrollable);
    const progress = totalScrollable > 0 ? scrolled / totalScrollable : 1;

    const thresholds = [0.03, 0.24, 0.46, 0.68];

    processCards.forEach((card, index) => {
      if (progress >= thresholds[index]) {
        card.classList.add('is-visible');
      }
    });
  };

  updateProcessCards();

  window.addEventListener('scroll', updateProcessCards, { passive: true });
  window.addEventListener('resize', updateProcessCards);
</script>