<section class="foundation source-container reveal">
  <h2>
    Construyendo bases digitales para empresas modernas.
  </h2>

  <p>
    Modernizamos operaciones mediante sistemas personalizados, automatización e
    información clara para tomar mejores decisiones.
  </p>
</section>

<style>
  .foundation {
    display: grid;
    grid-template-columns: 1fr 0.5fr;
    gap: 90px;
    padding: 86px 0;
  }

  .foundation h2 {
    margin: 0;
    font-size: var(--text-section);
    line-height: 1;
    font-weight: var(--weight-heading);
    letter-spacing: -0.06em;
  }

  .foundation p {
    margin: 0;
    align-self: start;
    color: var(--muted);
    font-size: var(--text-body-lg);
    line-height: 1.38;
    font-weight: var(--weight-body-strong);
    letter-spacing: -0.025em;
  }

  @media (max-width: 1100px) {
    .foundation {
      grid-template-columns: 1fr;
      gap: 36px;
    }
  }

  @media (max-width: 700px) {
    .foundation {
      padding: 64px 20px;
    }
  }
</style>