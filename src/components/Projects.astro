---
const projects = [
  {
    sector: "Restaurantes",
    title: "Punto de venta e inventario",
    image: "Imagen proyecto",
    imageUrl: "/images/restaurante.png"
  },
  {
    sector: "Comercios",
    title: "Control administrativo",
    image: "Imagen proyecto",
    imageUrl: "/images/administrativo.png"
  },
  {
    sector: "Servicios",
    title: "Pagina web",
    image: "Imagen proyecto",
    imageUrl: "/images/pagina_empresarial.png"
  },
];
---

<section id="trabajo" class="work-section source-container reveal">
  <div class="work-heading">
    <h2>Soluciones que podemos construir.</h2>

    
  </div>

  <div class="work-grid">
    {projects.map((project, index) => (
  <article class="stagger-item" style={`--i:${index}`}>
          

          <div
            class="image-slot work-image"
            style={`background-image: url('${project.imageUrl}')`}
            aria-label={project.image}
          ></div>

          <div class="work-content">
            <span>{project.sector}</span>
            <h3>{project.title}</h3>
          </div>
        </article>
      ))
    }
  </div>
</section>

<style>
  .work-section {
    padding: 86px 34px;
    border-left: 1px solid var(--line);
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .work-heading {
    display: grid;
    grid-template-columns: 1fr 0.5fr;
    gap: 80px;
    margin-bottom: 42px;
  }

  .work-heading h2 {
    margin: 0;
    font-size: var(--text-section);
    line-height: 1;
    font-weight: var(--weight-heading);
    letter-spacing: -0.06em;
  }

  .work-heading p {
    margin: 0;
    color: var(--muted);
    font-size: var(--text-body-lg);
    line-height: 1.38;
    font-weight: var(--weight-body-strong);
    letter-spacing: -0.025em;
  }

  .work-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }

  .work-grid article {
    background: var(--panel);
    transition:
      transform 0.35s cubic-bezier(0.16, 1, 0.3, 1),
      background 0.35s ease;
  }

  .work-grid article:hover {
    transform: translateY(-4px);
    background: white;
  }

  .work-image {
    height: 280px;
  }

  .work-content {
    padding: 24px;
  }

  .work-content span {
    color: var(--blue);
    font-size: 15px;
    font-weight: 900;
    text-transform: uppercase;
  }

  .work-content h3 {
    margin: 14px 0 0;
    font-size: 27px;
    line-height: 0.98;
    font-weight: 760;
    letter-spacing: -0.065em;
  }

  @media (max-width: 1100px) {
    .work-heading,
    .work-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 700px) {
    .work-section {
      padding: 80px 20px;
    }
  }
</style>
