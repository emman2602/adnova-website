---
import '../styles/source-theme.css';

import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  preloadHero?: boolean;
  showNav?: boolean;
  showFooter?: boolean;
}

const {
  title = 'ADNOVA® | Desarrollo de software para PyMEs en México',
  description = 'ADNOVA desarrolla software a medida, automatización, dashboards e integraciones para Pequeñas y Medianas empresas en México.',
  canonical = Astro.url.href,
  ogImage = 'https://adnovasoftware.com.mx/images/hero-adnova.webp',
  preloadHero = false,
  showNav = true,
  showFooter = true
} = Astro.props;

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': 'https://adnovasoftware.com.mx/#business',
  name: 'ADNOVA Software Solutions',
  url: 'https://adnovasoftware.com.mx',
  logo: 'https://adnovasoftware.com.mx/images/logoADNOVA.png',
  description:
    'Empresa de desarrollo de software a medida, automatización, sistemas administrativos, dashboards y páginas web para Pequeñas y Medianas empresas en México.',
  areaServed: 'México',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Oaxaca de Juárez',
    addressRegion: 'Oaxaca',
    addressCountry: 'MX'
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 17.0655,
    longitude: -96.7195
  },
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: '+52-951-269-0421',
    contactType: 'customer service',
    availableLanguage: ['Spanish']
  },
  sameAs: [
    'https://www.linkedin.com/company/adnovasoftware',
    'https://www.facebook.com/adnovasoftware'
  ]
};
---

<!doctype html>
<html lang="es-MX">
  <head>
    <meta charset="UTF-8" />
    <meta name="google-site-verification" content="FWxhjK_LlfD1R5lfyR-76hZL-W4QmZXPlSxUxNL7EOI" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_MX" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="ADNOVA Software Solutions" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {preloadHero && (
      <link
        rel="preload"
        as="image"
        href="/images/hero-adnova.webp"
        fetchpriority="high"
      />
    )}

    <link rel="icon" type="image/png" href="/favicon.png?v=3" />
    <link rel="shortcut icon" type="image/png" href="/favicon.png?v=3" />
    <link rel="apple-touch-icon" href="/favicon.png?v=3" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- Schema LocalBusiness (todas las páginas) -->
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />

    <!-- Slot para schemas adicionales por página (FAQPage, Service, etc.) -->
    <slot name="schema" />
  </head>

  <body>
    {showNav && <Nav />}

    <slot />

    {showFooter && <Footer />}

    <script>
      const animatedElements = document.querySelectorAll(
        '.reveal, .reveal-image, .reveal-soft, .stagger-item, .text-mask'
      );

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;

          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        });
      }, {
        threshold: 0.12,
        rootMargin: '0px 0px -60px 0px'
      });

      animatedElements.forEach((element) => observer.observe(element));
    </script>
  </body>
</html>