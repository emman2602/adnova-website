---
const differentials = [
  { title: 'Código que escala', desc: 'Arquitecturas diseñadas para crecer. Evitamos la deuda técnica que después cuesta el triple resolver.' },
  { title: 'Comunicación directa, sin intermediarios', desc: 'Trabajas con quien desarrolla. Sin cuentas comerciales que traduzcan mal tus requerimientos.' },
  { title: 'Transparencia total', desc: 'Repositorio propio, tablero de tareas y reuniones semanales de seguimiento. Sin cajas negras.' },
  { title: 'Seguridad desde el diseño', desc: 'Buenas prácticas de seguridad aplicadas en cada capa del sistema desde el principio.' },
  { title: 'Entregas en tiempo', desc: 'Sprints definidos y cumplidos. Te damos visibilidad real del avance en todo momento.' },
  { title: 'Soporte post-entrega', desc: 'No desaparecemos al entregar. Acompañamos el arranque y el mantenimiento a largo plazo.' },
];
---

<!-- ABOUT -->
<section id="nosotros" class="about">
  <div class="container">
    <div class="about-grid">
      <div class="about-left reveal-left">
        <div class="stag"><span class="stag-line"></span>Por qué ADNOVA</div>
        <h2 class="stitle">Comprometidos con<br>el <em>resultado real</em> de<br>tu proyecto</h2>
        <p class="about-desc">ADNOVA Software Solutions es una empresa mexicana de desarrollo de software enfocada en soluciones empresariales a medida. Trabajamos principalmente con PyMEs y empresas en crecimiento que necesitan tecnología adaptada a su operación real.

Somos un equipo compacto y técnicamente sólido. Eso nos permite responder rápido, comunicarnos sin intermediarios y mantener la calidad en cada proyecto sin la burocracia de las grandes agencias.</p>
        <a href="#contacto" class="about-cta">Hablemos de tu proyecto →</a>
        <div class="tech-stack">
          <span class="ts-label">Tecnologías que dominamos</span>
          <div class="ts-items">
            <span>React</span><span>Node.js</span><span>Python</span>
            <span>PostgreSQL</span><span>AWS</span><span>Docker</span><span>.NET</span>
          </div>
        </div>
      </div>
      <div class="about-right">
        <div class="diff-grid">
          {differentials.map((d, i) => (
            <div class={`diff-card reveal delay-${(i % 3) + 1}`}>
              <div class="dc-num">0{i+1}</div>
              <h4 class="dc-title">{d.title}</h4>
              <p class="dc-desc">{d.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CONTACT -->
<section id="contacto" class="contact">
  <div class="container">
    <div class="contact-inner reveal">
      <div class="contact-left">
        <div class="stag light"><span class="stag-line" style="background:rgba(255,255,255,0.35)"></span>Hablemos</div>
        <h2 class="contact-title">¿Tienes un proyecto<br><em>en mente?</em></h2>
        <p class="contact-sub">Cuéntanos qué necesitas. En menos de 48 horas te respondemos con una propuesta inicial, sin costo ni compromiso.</p>
        <div class="contact-channels">
          <a href="https://wa.me/529512690421?text=Hola%20ADNOVA%2C%20me%20interesa%20cotizar%20un%20proyecto" target="_blank" class="ch-wa">
            <svg class="ch-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Escríbenos por WhatsApp
          </a>
          <div class="contact-or">o déjanos tus datos</div>
          <div class="contact-info-items">
            <div class="cii">
              <svg viewBox="0 0 18 18" fill="none"><path d="M2 4l7 5 7-5M2 4h14v11a1 1 0 01-1 1H3a1 1 0 01-1-1V4z" stroke="rgba(255,255,255,0.5)" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <a href="mailto:hola@adnova.mx">hola@adnova.mx</a>
            </div>
            <div class="cii">
              <svg viewBox="0 0 18 18" fill="none"><path d="M2 4a1 1 0 011-1h2.5l1.5 3.5L5.5 8a10 10 0 004.5 4.5l1.5-1.5L15 12.5V15a1 1 0 01-1 1C7 16 2 11 2 5V4z" stroke="rgba(255,255,255,0.5)" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <a href="tel:+529512690421">+52 951 269 0421</a>
            </div>
          </div>
        </div>
      </div>

      <div class="contact-form-wrap">
        <h3 class="form-title">Cuéntanos tu proyecto</h3>
        <form class="contact-form" id="contact-form">
          <div class="form-row">
            <div class="form-group">
              <label>Nombre</label>
              <input type="text" name="name" placeholder="Tu nombre" required />
            </div>
            <div class="form-group">
              <label>Correo electrónico</label>
              <input type="email" name="email" placeholder="tu@empresa.com" required />
            </div>
          </div>
          <div class="form-group">
            <label>Empresa</label>
            <input type="text" name="company" placeholder="Nombre de tu empresa" />
          </div>
          <div class="form-group">
            <label>Servicio de interés</label>
            <select name="service">
              <option value="">Selecciona...</option>
              <option>Sistemas empresariales / ERP</option>
              <option>Automatización de procesos</option>
              <option>Integraciones y APIs</option>
              <option>Desarrollo web y móvil</option>
              <option>Mantenimiento y soporte</option>
              <option>Varios servicios</option>
            </select>
          </div>
          <div class="form-group">
            <label>Describe tu proyecto</label>
            <textarea name="message" rows="4" placeholder="¿Qué problema necesitas resolver? ¿Tienes un plazo estimado?" required></textarea>
          </div>
          <button type="submit" class="form-submit" id="submit-btn">
            Enviar solicitud →
          </button>
          <div id="form-success" class="form-success" style="display:none">
            ✓ ¡Recibido! Te escribimos en menos de 48 horas.
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer class="footer">
  <div class="container">
    <div class="footer-inner">
      <div class="footer-brand">
        <div class="footer-logo">
          <span class="lm">AD</span><span class="lt">NOVA</span>
        </div>
        <p>Construimos el software que tu empresa necesita.</p>
      </div>
      <div class="footer-links">
        <div class="fl-group">
          <span class="fl-head">Servicios</span>
          <a href="#servicios">Sistemas empresariales</a>
          <a href="#servicios">Automatización</a>
          <a href="#servicios">Integraciones y APIs</a>
          <a href="#servicios">Desarrollo web y móvil</a>
          <a href="#servicios">Mantenimiento</a>
        </div>
        <div class="fl-group">
          <span class="fl-head">Empresa</span>
          <a href="#nosotros">Nosotros</a>
          <a href="#proceso">Proceso</a>
          <a href="#proyectos">Proyectos</a>
          <a href="#contacto">Contacto</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© 2025 ADNOVA. Todos los derechos reservados.</span>
      <span>Hecho en México 🇲🇽</span>
    </div>
  </div>
</footer>

<style>
/* ABOUT */
.about { padding: 7rem 2rem; background: white; }
.container { max-width: 1280px; margin: 0 auto; }
.about-grid { display: grid; grid-template-columns: 1fr 1.1fr; gap: 6rem; align-items: center; }
.stag { display: inline-flex; align-items: center; gap: 0.7rem; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--blue); margin-bottom: 1rem; }
.stag.light { color: rgba(255,255,255,0.55); }
.stag-line { display: block; width: 22px; height: 2px; background: var(--blue); border-radius: 1px; }
.stitle { font-family: 'Syne', sans-serif; font-size: clamp(1.9rem, 3.5vw, 2.7rem); font-weight: 700; line-height: 1.15; color: var(--text-dark); margin-bottom: 1.1rem; }
.stitle em { font-style: italic; font-weight: 400; color: var(--blue); }
.about-desc { font-size: 0.95rem; color: var(--text-mid); line-height: 1.82; margin-bottom: 1.8rem; }
.about-cta {
  display: inline-block; background: var(--blue); color: white;
  padding: 0.82rem 1.8rem; border-radius: 8px; font-size: 0.88rem; font-weight: 600;
  text-decoration: none; margin-bottom: 2.2rem;
  box-shadow: 0 4px 14px rgba(59,91,215,0.3); transition: all 0.22s;
}
.about-cta:hover { background: var(--blue-dark); transform: translateY(-1px); }
.ts-label { display: block; font-size: 0.68rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 0.65rem; }
.ts-items { display: flex; flex-wrap: wrap; gap: 0.45rem; }
.ts-items span {
  font-size: 0.75rem; font-weight: 600; background: var(--blue-ghost);
  color: var(--text-mid); border: 1px solid var(--border);
  padding: 0.28rem 0.75rem; border-radius: 100px;
}
.diff-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
.diff-card {
  background: var(--off-white); border: 1px solid var(--border);
  border-radius: 10px; padding: 1.4rem; transition: all 0.25s;
}
.diff-card:hover { border-color: var(--blue); box-shadow: 0 6px 24px rgba(59,91,215,0.09); transform: translateY(-2px); }
.dc-num { font-family: 'Syne', sans-serif; font-size: 0.65rem; font-weight: 800; color: var(--blue-light); opacity: 0.6; margin-bottom: 0.6rem; }
.dc-title { font-size: 0.9rem; font-weight: 700; color: var(--text-dark); margin-bottom: 0.4rem; }
.dc-desc { font-size: 0.8rem; color: var(--text-muted); line-height: 1.65; }

/* CONTACT */
.contact {
  padding: 7rem 2rem;
  background: linear-gradient(135deg, var(--blue-deeper) 0%, var(--slate) 100%);
  position: relative; overflow: hidden;
}
.contact::before {
  content: ''; position: absolute; top: -180px; right: -180px;
  width: 500px; height: 500px; border-radius: 50%;
  background: radial-gradient(circle, rgba(59,91,215,0.28), transparent 70%);
  pointer-events: none;
}
.contact-inner { display: grid; grid-template-columns: 1fr 1.15fr; gap: 5rem; align-items: start; position: relative; z-index: 1; }
.contact-title { font-family: 'Syne', sans-serif; font-size: clamp(1.9rem, 3.5vw, 2.7rem); font-weight: 700; line-height: 1.15; color: white; margin-bottom: 1rem; }
.contact-title em { font-style: italic; font-weight: 400; color: var(--blue-pale); }
.contact-sub { font-size: 0.94rem; color: rgba(255,255,255,0.52); line-height: 1.8; margin-bottom: 2rem; }
.contact-channels { display: flex; flex-direction: column; gap: 1rem; }
.ch-wa {
  display: flex; align-items: center; gap: 0.75rem;
  background: #25D366; color: white;
  padding: 0.9rem 1.5rem; border-radius: 10px;
  font-size: 0.9rem; font-weight: 700; text-decoration: none;
  transition: all 0.22s; width: fit-content;
  box-shadow: 0 4px 16px rgba(37,211,102,0.35);
}
.ch-wa:hover { background: #1ebe5d; transform: translateY(-1px); box-shadow: 0 8px 24px rgba(37,211,102,0.45); }
.ch-icon { width: 20px; height: 20px; flex-shrink: 0; }
.contact-or { font-size: 0.78rem; color: rgba(255,255,255,0.3); text-align: left; }
.contact-info-items { display: flex; flex-direction: column; gap: 0.7rem; }
.cii { display: flex; align-items: center; gap: 0.65rem; }
.cii svg { width: 16px; height: 16px; flex-shrink: 0; }
.cii a, .cii span { font-size: 0.88rem; color: rgba(255,255,255,0.62); text-decoration: none; transition: color 0.2s; }
.cii a:hover { color: white; }

/* FORM */
.contact-form-wrap { background: white; border-radius: 16px; padding: 2.5rem; box-shadow: 0 24px 60px rgba(0,0,0,0.28); }
.form-title { font-family: 'Syne', sans-serif; font-size: 1.2rem; font-weight: 700; color: var(--text-dark); margin-bottom: 1.5rem; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
.form-group { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 0.9rem; }
.form-group label { font-size: 0.78rem; font-weight: 600; color: var(--text-mid); }
.form-group input, .form-group select, .form-group textarea {
  border: 1.5px solid var(--border); border-radius: 8px;
  padding: 0.72rem 0.95rem; font-family: 'Outfit', sans-serif;
  font-size: 0.88rem; color: var(--text-dark); background: white;
  transition: border-color 0.2s, box-shadow 0.2s; resize: none; outline: none;
}
.form-group input:focus, .form-group select:focus, .form-group textarea:focus {
  border-color: var(--blue); box-shadow: 0 0 0 3px rgba(59,91,215,0.1);
}
.form-group input::placeholder, .form-group textarea::placeholder { color: var(--text-muted); }
.form-submit {
  width: 100%; background: var(--blue); color: white; border: none;
  padding: 0.95rem; border-radius: 8px; font-family: 'Outfit', sans-serif;
  font-size: 0.92rem; font-weight: 600; cursor: pointer; transition: all 0.22s;
  box-shadow: 0 4px 16px rgba(59,91,215,0.3);
}
.form-submit:hover { background: var(--blue-dark); transform: translateY(-1px); }
.form-success {
  text-align: center; padding: 1rem; background: #ecfdf5;
  border: 1px solid #a7f3d0; color: #047857;
  border-radius: 8px; font-size: 0.9rem; font-weight: 500; margin-top: 0.75rem;
}

/* FOOTER */
.footer { background: var(--slate); padding: 3rem 2rem 2rem; }
.footer-inner { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2rem; gap: 3rem; flex-wrap: wrap; }
.footer-logo { display: flex; margin-bottom: 0.7rem; }
.lm { background: var(--blue); color: white; font-family: 'Syne', sans-serif; font-size: 0.9rem; font-weight: 800; padding: 0.25rem 0.4rem; border-radius: 4px 0 0 4px; letter-spacing: 0.04em; }
.lt { background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.75); font-family: 'Syne', sans-serif; font-size: 0.9rem; font-weight: 700; padding: 0.25rem 0.4rem; border-radius: 0 4px 4px 0; letter-spacing: 0.08em; }
.footer-brand p { font-size: 0.8rem; color: rgba(255,255,255,0.3); max-width: 200px; line-height: 1.6; }
.footer-links { display: flex; gap: 3.5rem; }
.fl-group { display: flex; flex-direction: column; gap: 0.55rem; }
.fl-head { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255,255,255,0.28); margin-bottom: 0.3rem; }
.fl-group a { font-size: 0.82rem; color: rgba(255,255,255,0.45); text-decoration: none; transition: color 0.2s; }
.fl-group a:hover { color: white; }
.footer-bottom { border-top: 1px solid rgba(255,255,255,0.06); padding-top: 1.5rem; display: flex; justify-content: space-between; font-size: 0.73rem; color: rgba(255,255,255,0.18); flex-wrap: wrap; gap: 0.5rem; }

@media (max-width: 900px) {
  .about-grid { grid-template-columns: 1fr; gap: 3rem; }
  .diff-grid { grid-template-columns: 1fr; }
  .contact-inner { grid-template-columns: 1fr; gap: 3rem; }
  .form-row { grid-template-columns: 1fr; }
  .footer-inner { flex-direction: column; }
  .footer-links { gap: 2rem; }
}
</style>

<script>
const form = document.getElementById('contact-form') as HTMLFormElement;
const success = document.getElementById('form-success');
const btn = document.getElementById('submit-btn');
form?.addEventListener('submit', (e) => {
  e.preventDefault();
  if(btn) btn.textContent = 'Enviando...';
  setTimeout(() => {
    if(form) form.style.display = 'none';
    if(success) success.style.display = 'block';
  }, 1100);
});
</script>
