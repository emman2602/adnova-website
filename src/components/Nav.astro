---
---

<header class="topbar" id="topbar">
  <a href="/" class="brand" aria-label="ADNOVA - Ir al inicio">
    <img
      src="/images/logoCompletoOriginalSinFondo.svg"
      alt="ADNOVA Software Solutions"
      class="brand-logo"
    />
  </a>

  <div class="location">
    <span>Oaxaca, MX</span>
    <i></i>
    <span id="local-time">--:--</span>
  </div>

  <nav class="desktop-nav" aria-label="Navegación principal">
    <a href="/" class="nav-cell">Inicio</a>
    <a href="/nosotros" class="nav-cell">Nosotros</a>
    <a href="/servicios" class="nav-cell">Servicios</a>
    <a href="/#trabajo" class="nav-cell">Proyectos</a>
    <a href="/#proceso" class="nav-cell">Proceso</a>
  </nav>

  <a href="/#contacto" class="contact-cell">Contacto</a>

  <button
    class="menu-button"
    id="menu-button"
    type="button"
    aria-label="Abrir menú"
    aria-expanded="false"
    aria-controls="mobile-menu"
  >
    <span></span>
    <span></span>
  </button>
</header>

<nav class="mobile-menu" id="mobile-menu" aria-label="Menú móvil">
  <a href="/">Inicio</a>
  <a href="/nosotros">Nosotros</a>
  <a href="/servicios">Servicios</a>
  <a href="/#trabajo">Proyectos</a>
  <a href="/#proceso">Proceso</a>
  <a href="/#contacto">Contacto</a>
</nav>

<style>
  .topbar {
    position: sticky;
    top: 0;
    z-index: 80;
    height: 64px;
    display: grid;
    grid-template-columns: 1.25fr 0.9fr 4fr 0.8fr;
    border-bottom: 1px solid var(--line);
    background: rgba(243, 242, 237, 0.94);
    backdrop-filter: blur(18px);
  }

  .brand,
  .location,
  .contact-cell,
  .menu-button {
    display: flex;
    align-items: center;
    min-height: 64px;
    padding: 0 28px;
    border-right: 1px solid var(--line);
    color: var(--ink);
    text-decoration: none;
  }

  .brand {
  justify-content: flex-start;
  overflow: hidden;
}

.brand-logo {
  width: 200px;
  height: auto;
  max-height: 54px;
  display: block;
  object-fit: contain;
  object-position: left center;
}

  .location {
    justify-content: center;
    gap: 13px;
    font-size: 15px;
    font-weight: var(--weight-medium, 460);
    white-space: nowrap;
  }

  .location i {
    width: 11px;
    height: 11px;
    flex: 0 0 auto;
    background: var(--blue);
  }

  .desktop-nav {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    min-width: 0;
  }

  .nav-cell {
    min-height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 18px;
    border-right: 1px solid var(--line);
    color: var(--ink);
    font-size: 15px;
    line-height: 1;
    font-weight: var(--weight-medium, 460);
    text-decoration: none;
    transition:
      background 0.25s ease,
      color 0.25s ease;
  }

  .nav-cell:hover {
    background: var(--black);
    color: white;
  }

  .contact-cell {
    justify-content: center;
    border-right: 0;
    background: var(--blue);
    color: white;
    font-size: 15px;
    font-weight: var(--weight-medium, 460);
    transition: background 0.25s ease;
  }

  .contact-cell:hover {
    background: var(--blue-dark);
  }

  .menu-button {
    display: none;
    justify-content: center;
    gap: 6px;
    flex-direction: column;
    border: 0;
    border-left: 1px solid var(--line);
    background: transparent;
    cursor: pointer;
  }

  .menu-button span {
    width: 22px;
    height: 2px;
    background: var(--ink);
    transition:
      transform 0.25s ease,
      opacity 0.25s ease;
  }

  .menu-button.is-open span:first-child {
    transform: translateY(4px) rotate(45deg);
  }

  .menu-button.is-open span:last-child {
    transform: translateY(-4px) rotate(-45deg);
  }

  .mobile-menu {
    position: fixed;
    top: 64px;
    left: 0;
    right: 0;
    z-index: 70;
    display: grid;
    background: rgba(244, 241, 232, 0.98);
    border-bottom: 1px solid var(--line);
    backdrop-filter: blur(18px);
    transform: translateY(-115%);
    opacity: 0;
    pointer-events: none;
    transition:
      transform 0.32s cubic-bezier(.16, 1, .3, 1),
      opacity 0.32s ease;
  }

  .mobile-menu.is-open {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }

  .mobile-menu a {
    min-height: 58px;
    display: flex;
    align-items: center;
    padding: 0 20px;
    border-bottom: 1px solid var(--line);
    color: var(--ink);
    font-size: 18px;
    font-weight: var(--weight-medium, 460);
    text-decoration: none;
  }

  .mobile-menu a:hover {
    background: var(--blue);
    color: white;
  }

  @media (max-width: 1180px) {
    .topbar {
      grid-template-columns: 1.1fr 0.8fr 4fr 0.8fr;
    }

    .brand,
    .location,
    .contact-cell {
      padding-left: 22px;
      padding-right: 22px;
    }

    .nav-cell {
      padding-left: 12px;
      padding-right: 12px;
      font-size: 14px;
    }

    .brand-logo {
    width: 180px;
    max-height: 50px;
  }
  }

  @media (max-width: 900px) {
    .topbar {
      grid-template-columns: 1fr auto auto;
      height: 60px;
    }

    .brand {
      min-height: 60px;
      padding: 0 18px;
    }

    .brand-logo {
    width: 180px;
    max-height: 46px;
  }
    .location,
    .desktop-nav {
      display: none;
    }

    .contact-cell {
      min-height: 60px;
      padding: 0 18px;
      font-size: 14px;
      border-left: 1px solid var(--line);
      border-right: 0;
    }

    .menu-button {
      min-height: 60px;
      width: 62px;
      display: flex;
      padding: 0;
    }

    .mobile-menu {
      top: 60px;
    }
  }

  @media (max-width: 520px) {
    .topbar {
      grid-template-columns: 1fr auto;
    }

    .contact-cell {
      display: none;
    }

    .menu-button {
      width: 58px;
    }

    .brand-logo {
    width: 180px;
    max-height: 42px;
  }
  }
</style>

<script>
  const timeElement = document.getElementById('local-time');

  function updateTime() {
    if (!timeElement) return;

    timeElement.textContent = new Intl.DateTimeFormat('es-MX', {
      hour: 'numeric',
      minute: '2-digit',
      hour12: true,
      timeZone: 'America/Mexico_City'
    }).format(new Date());
  }

  updateTime();
  setInterval(updateTime, 60000);

  const menuButton = document.getElementById('menu-button');
  const mobileMenu = document.getElementById('mobile-menu');

  menuButton?.addEventListener('click', () => {
    const isOpen = menuButton.classList.toggle('is-open');

    mobileMenu?.classList.toggle('is-open', isOpen);
    menuButton.setAttribute('aria-expanded', String(isOpen));
  });

  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menuButton?.classList.remove('is-open');
      mobileMenu.classList.remove('is-open');
      menuButton?.setAttribute('aria-expanded', 'false');
    });
  });
</script>