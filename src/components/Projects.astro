---
const projects = [
  {
    status: "Proyecto interno",
    sector: "Presencia digital",
    title: "Sitio web corporativo ADNOVA",
    description:
      "Sitio web empresarial desarrollado para presentar servicios, generar confianza y facilitar el contacto con clientes potenciales.",
    imageUrl: "/images/pagina_empresarial.webp",
    alt: "Sitio web corporativo desarrollado para ADNOVA Software Solutions",
    position: "top center"
  },
  {
    status: "En desarrollo",
    sector: "Plataforma privada",
    title: "Catálogo privado de productores",
    description:
      "Plataforma web para administrar productores, productos, categorías, filtros, contactos y métricas operativas.",
    imageUrl: "/images/administrativo.webp",
    alt: "Panel administrativo para catálogo privado de productores",
    position: "center center"
  },
  {
    status: "Demo funcional",
    sector: "Administración PyME",
    title: "Sistema administrativo e inventario",
    description:
      "Demo de sistema interno para centralizar productos, clientes, ventas, usuarios, inventario y reportes.",
    imageUrl: "/images/sistema_admin.webp",
    alt: "Sistema administrativo e inventario para PyMEs",
    position: "center center"
  }
];
---

<section id="trabajo" class="work-section source-container reveal">
  <div class="work-heading">
    <span>Proyectos</span>

    <h2>Una muestra de lo que estamos construyendo.</h2>

    <p>
      Proyectos internos, demostrativos y plataformas en desarrollo que reflejan
      nuestro enfoque: soluciones claras, útiles y pensadas para negocios reales.
    </p>
  </div>

  <div class="work-grid">
    {
      projects.map((project, index) => (
        <article class="work-card stagger-item" style={`--i:${index}`}>
          <a href="/proyectos" class="work-link" aria-label={`Ver detalles de ${project.title}`}>
            <div class="work-image">
              <img
                src={project.imageUrl}
                alt={project.alt}
                loading="lazy"
                decoding="async"
                style={`object-position: ${project.position};`}
              />

              <span class="work-status">{project.status}</span>
            </div>

            <div class="work-content">
              <span class="work-sector">{project.sector}</span>
              <h3>{project.title}</h3>
              <p>{project.description}</p>

              <div class="work-more">
                Ver proyecto
                <strong>↗</strong>
              </div>
            </div>
          </a>
        </article>
      ))
    }
  </div>

  <div class="work-footer">
    <a href="/proyectos" class="work-button">
      Ver todos los proyectos
      <strong>↗</strong>
    </a>
  </div>
</section>

<style>
  .work-section {
    padding: 86px 34px 96px;
    border-left: 1px solid var(--line);
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    background: var(--bg);
  }

  .work-heading {
    display: grid;
    grid-template-columns: 0.58fr 0.42fr;
    gap: 80px;
    align-items: end;
    margin-bottom: 42px;
  }

  .work-heading > span {
    grid-column: 1 / -1;
    width: fit-content;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--blue);
    font-size: 12px;
    line-height: 1;
    font-weight: var(--weight-strong);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .work-heading > span::before {
    content: "";
    width: 8px;
    height: 8px;
    background: var(--blue);
  }

  .work-heading h2 {
    margin: 0;
    max-width: 920px;
    color: var(--ink);
    font-size: var(--text-section);
    line-height: 1;
    font-weight: var(--weight-heading);
    letter-spacing: -0.065em;
  }

  .work-heading p {
    max-width: 560px;
    margin: 0;
    color: var(--muted);
    font-size: var(--text-body-lg);
    line-height: 1.42;
    font-weight: var(--weight-body);
    letter-spacing: -0.025em;
  }

  .work-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .work-card {
    overflow: hidden;
    background: var(--panel);
    transition:
      transform 0.35s cubic-bezier(0.16, 1, 0.3, 1),
      background 0.35s ease,
      box-shadow 0.35s ease;
  }

  .work-card:hover {
    transform: translateY(-6px);
    background: #ffffff;
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.08);
  }

  .work-link {
    display: grid;
    height: 100%;
    color: inherit;
    text-decoration: none;
  }

  .work-image {
    position: relative;
    height: clamp(270px, 20vw, 390px);
    overflow: hidden;
    background: var(--panel);
    border-bottom: 1px solid var(--line);
  }

  .work-image img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    transition:
      transform 0.6s cubic-bezier(0.16, 1, 0.3, 1),
      filter 0.35s ease;
  }

  .work-card:hover .work-image img {
    transform: scale(1.045);
    filter: contrast(1.04);
  }

  .work-status {
    position: absolute;
    left: 18px;
    bottom: 18px;
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    padding: 0 12px;
    background: rgba(248, 247, 245, 0.92);
    color: var(--blue);
    font-size: 12px;
    line-height: 1;
    font-weight: var(--weight-strong);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    backdrop-filter: blur(12px);
  }

  .work-content {
    min-height: 230px;
    display: grid;
    align-content: start;
    gap: 16px;
    padding: 24px;
  }

  .work-sector {
    color: var(--blue);
    font-size: 12px;
    line-height: 1;
    font-weight: var(--weight-strong);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .work-content h3 {
    margin: 0;
    color: var(--ink);
    font-size: clamp(25px, 2vw, 34px);
    line-height: 0.98;
    font-weight: var(--weight-heading);
    letter-spacing: -0.062em;
  }

  .work-content p {
    margin: 0;
    color: var(--muted);
    font-size: 15px;
    line-height: 1.45;
    font-weight: var(--weight-body);
    letter-spacing: -0.02em;
  }

  .work-more {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    margin-top: auto;
    padding-top: 18px;
    border-top: 1px solid var(--line);
    color: var(--blue);
    font-size: 14px;
    font-weight: var(--weight-medium);
  }

  .work-more strong {
    font-size: 22px;
    font-weight: 400;
  }

  .work-footer {
    display: flex;
    justify-content: center;
    margin-top: 42px;
  }

  .work-button {
    min-height: 58px;
    display: inline-flex;
    align-items: center;
    gap: 24px;
    padding: 0 24px;
    background: var(--black);
    color: white;
    font-size: 15px;
    font-weight: var(--weight-medium);
    text-decoration: none;
    transition:
      background 0.25s ease,
      transform 0.25s ease;
  }

  .work-button:hover {
    background: var(--blue);
    transform: translateY(-2px);
  }

  .work-button strong {
    font-size: 24px;
    font-weight: 400;
  }

  @media (max-width: 1100px) {
    .work-heading {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .work-grid {
      grid-template-columns: 1fr;
    }

    .work-image {
      height: 430px;
    }
  }

  @media (max-width: 700px) {
    .work-section {
      padding: 70px 20px;
      border-left: 0;
      border-right: 0;
    }

    .work-heading {
      margin-bottom: 34px;
    }

    .work-heading h2 {
      font-size: clamp(34px, 9vw, 48px);
      line-height: 1.02;
    }

    .work-heading p {
      font-size: 17px;
    }

    .work-grid {
      gap: 16px;
    }

    .work-image {
      height: 280px;
    }

    .work-content {
      min-height: auto;
      padding: 22px;
    }

    .work-content h3 {
      font-size: clamp(27px, 8vw, 38px);
    }

    .work-footer {
      justify-content: stretch;
    }

    .work-button {
      width: 100%;
      justify-content: space-between;
    }
  }
</style>