---
// src/pages/aviso-privacidad.astro
// Coloca este archivo en: src/pages/aviso-privacidad.astro
const title = "Aviso de privacidad | ADNOVA Software Solutions";
const description = "Aviso de privacidad de ADNOVA Software Solutions en cumplimiento de la Ley Federal de Protección de Datos Personales en Posesión de los Particulares (LFPDPPP).";
const canonical = "https://adnovasoftware.com.mx/aviso-privacidad";
const lastUpdated = "Junio 2026";
---

<!DOCTYPE html>
<html lang="es-MX">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta name="robots" content="index, follow" />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:locale" content="es_MX" />
  <meta property="og:site_name" content="ADNOVA Software Solutions" />
  <meta property="og:type" content="website" />

  <!-- Fuente y estilos -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --color-bg: #ffffff;
      --color-text: #1a1a1a;
      --color-text-muted: #555;
      --color-border: #e5e5e5;
      --color-accent: #1a1a1a;
      --font: 'Inter', sans-serif;
    }

    body {
      font-family: var(--font);
      background: var(--color-bg);
      color: var(--color-text);
      line-height: 1.75;
      font-size: 1rem;
    }

    /* ── Nav (igual al resto del sitio) ───────────────────── */
    .nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.25rem 2rem;
      border-bottom: 1px solid var(--color-border);
    }
    .nav a { text-decoration: none; color: var(--color-text); font-size: 0.875rem; }
    .nav-logo { font-weight: 500; font-size: 1rem; letter-spacing: -0.02em; }
    .nav-back {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      color: var(--color-text-muted);
      font-size: 0.875rem;
      transition: color 0.15s;
    }
    .nav-back:hover { color: var(--color-text); }

    /* ── Layout ───────────────────────────────────────────── */
    .page {
      max-width: 720px;
      margin: 0 auto;
      padding: 4rem 2rem 6rem;
    }

    /* ── Header del documento ─────────────────────────────── */
    .doc-header {
      border-bottom: 1px solid var(--color-border);
      padding-bottom: 2rem;
      margin-bottom: 3rem;
    }
    .doc-eyebrow {
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-text-muted);
      margin-bottom: 0.75rem;
    }
    .doc-title {
      font-size: clamp(1.5rem, 4vw, 2rem);
      font-weight: 500;
      letter-spacing: -0.03em;
      line-height: 1.2;
      margin-bottom: 1rem;
    }
    .doc-meta {
      font-size: 0.875rem;
      color: var(--color-text-muted);
    }
    .doc-meta span + span::before { content: " · "; }

    /* ── Secciones ────────────────────────────────────────── */
    .section {
      margin-bottom: 2.5rem;
    }
    .section-number {
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--color-text-muted);
      display: block;
      margin-bottom: 0.4rem;
    }
    .section h2 {
      font-size: 1rem;
      font-weight: 500;
      margin-bottom: 0.75rem;
      letter-spacing: -0.01em;
    }
    .section p {
      font-size: 0.9375rem;
      color: var(--color-text-muted);
      margin-bottom: 0.75rem;
    }
    .section p:last-child { margin-bottom: 0; }
    .section ul {
      list-style: none;
      padding: 0;
      margin: 0.5rem 0 0.75rem;
    }
    .section ul li {
      font-size: 0.9375rem;
      color: var(--color-text-muted);
      padding: 0.3rem 0 0.3rem 1.25rem;
      position: relative;
    }
    .section ul li::before {
      content: "—";
      position: absolute;
      left: 0;
      color: #bbb;
    }

    /* ── Cuadro destacado (datos de contacto) ─────────────── */
    .contact-box {
      border: 1px solid var(--color-border);
      border-radius: 8px;
      padding: 1.25rem 1.5rem;
      margin-top: 0.75rem;
      background: #fafafa;
    }
    .contact-box p {
      margin: 0;
      font-size: 0.9rem;
    }
    .contact-box a {
      color: var(--color-text);
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    /* ── Footer ───────────────────────────────────────────── */
    .footer {
      border-top: 1px solid var(--color-border);
      padding: 2rem;
      text-align: center;
      font-size: 0.8125rem;
      color: var(--color-text-muted);
    }
    .footer a { color: var(--color-text-muted); text-decoration: underline; text-underline-offset: 3px; }
  </style>
</head>

<body>

  <!-- Navegación -->
  <nav class="nav">
    <a href="/" class="nav-logo">◆ ADNOVA®</a>
    <a href="/" class="nav-back">← Volver al inicio</a>
  </nav>

  <!-- Contenido principal -->
  <main class="page">

    <header class="doc-header">
      <p class="doc-eyebrow">Documento legal</p>
      <h1 class="doc-title">Aviso de privacidad</h1>
      <div class="doc-meta">
        <span>ADNOVA Software Solutions</span>
        <span>Última actualización: {lastUpdated}</span>
        <span>Oaxaca, México</span>
      </div>
    </header>

    <!-- 1. Responsable -->
    <div class="section">
      <span class="section-number">01</span>
      <h2>Responsable del tratamiento de datos personales</h2>
      <p>
        <strong>ADNOVA Software Solutions</strong> (en adelante "ADNOVA"), con domicilio en la ciudad de
        Oaxaca de Juárez, Oaxaca, México, es responsable del uso y protección de sus datos personales.
      </p>
      <p>
        Para cualquier asunto relacionado con este aviso de privacidad puede contactarnos a través de los
        medios indicados en la sección de contacto al final de este documento.
      </p>
    </div>

    <!-- 2. Datos que recabamos -->
    <div class="section">
      <span class="section-number">02</span>
      <h2>Datos personales que recabamos</h2>
      <p>
        Para las finalidades descritas en este aviso, ADNOVA recaba únicamente los siguientes datos personales
        de identificación y contacto:
      </p>
      <ul>
        <li>Nombre completo</li>
        <li>Correo electrónico</li>
        <li>Número de teléfono o WhatsApp</li>
      </ul>
      <p>
        ADNOVA <strong>no recaba datos personales sensibles</strong> (como datos financieros, de salud,
        ideología política, origen racial o étnico) a través de sus canales digitales.
      </p>
    </div>

    <!-- 3. Finalidades -->
    <div class="section">
      <span class="section-number">03</span>
      <h2>Finalidades del tratamiento</h2>
      <p>Sus datos personales son utilizados para las siguientes finalidades <strong>primarias</strong>,
      necesarias para la relación que usted establece con nosotros:</p>
      <ul>
        <li>Atender solicitudes de diagnóstico, cotización o información sobre nuestros servicios.</li>
        <li>Dar seguimiento a proyectos de desarrollo de software y soluciones digitales.</li>
        <li>Enviar información relacionada con el avance o entrega de un proyecto contratado.</li>
      </ul>
      <p>De manera <strong>secundaria</strong>, y solo con su consentimiento, podríamos utilizar sus datos para:</p>
      <ul>
        <li>Enviar comunicaciones sobre actualizaciones, nuevos servicios o contenido de valor relacionado con
        la transformación digital de PyMEs.</li>
      </ul>
      <p>Si no desea que sus datos sean utilizados para estas finalidades secundarias, puede manifestarlo
      enviando un correo a la dirección indicada en la sección de contacto.</p>
    </div>

    <!-- 4. Transferencia -->
    <div class="section">
      <span class="section-number">04</span>
      <h2>Transferencia de datos a terceros</h2>
      <p>
        ADNOVA <strong>no comparte, vende ni transfiere</strong> sus datos personales a terceros, salvo en
        los casos previstos por el artículo 37 de la LFPDPPP, que no requieren su consentimiento (por ejemplo,
        cuando sea requerido por autoridad competente o por mandato legal).
      </p>
      <p>
        Podemos hacer uso de servicios de infraestructura tecnológica de terceros (como servidores de correo
        o plataformas de comunicación) estrictamente para operar nuestros canales de contacto. Dichos
        proveedores están obligados contractualmente a tratar sus datos conforme a este aviso.
      </p>
    </div>

    <!-- 5. Derechos ARCO -->
    <div class="section">
      <span class="section-number">05</span>
      <h2>Sus derechos ARCO</h2>
      <p>
        Usted tiene derecho a <strong>Acceder</strong> a sus datos personales en nuestro poder, <strong>Rectificarlos</strong>
        si son inexactos o incompletos, <strong>Cancelarlos</strong> cuando considere que no son necesarios
        para las finalidades señaladas, y <strong>Oponerse</strong> a su tratamiento para fines específicos.
      </p>
      <p>
        Para ejercer cualquiera de estos derechos, envíe una solicitud a través de los medios de contacto
        indicados a continuación, indicando: su nombre completo, el derecho que desea ejercer y una
        descripción clara de su solicitud. Daremos respuesta en un plazo máximo de <strong>20 días hábiles</strong>.
      </p>
    </div>

    <!-- 6. Consentimiento -->
    <div class="section">
      <span class="section-number">06</span>
      <h2>Consentimiento</h2>
      <p>
        Al completar y enviar el formulario de contacto en este sitio web, usted manifiesta haber leído y
        aceptado los términos del presente aviso de privacidad, y otorga su consentimiento para el
        tratamiento de sus datos con las finalidades primarias aquí descritas.
      </p>
    </div>

    <!-- 7. Cookies -->
    <div class="section">
      <span class="section-number">07</span>
      <h2>Uso de cookies y tecnologías de seguimiento</h2>
      <p>
        Este sitio web puede utilizar cookies técnicas necesarias para su funcionamiento. No utilizamos
        cookies de seguimiento publicitario ni compartimos información de navegación con terceros con fines
        comerciales.
      </p>
      <p>
        Puede configurar su navegador para rechazar o eliminar cookies, aunque esto puede afectar la
        funcionalidad del sitio.
      </p>
    </div>

    <!-- 8. Cambios al aviso -->
    <div class="section">
      <span class="section-number">08</span>
      <h2>Cambios al aviso de privacidad</h2>
      <p>
        ADNOVA se reserva el derecho de actualizar este aviso de privacidad en cualquier momento para
        reflejar cambios en nuestras prácticas o en la legislación aplicable. Cualquier modificación
        será publicada en esta misma página con la fecha de última actualización.
      </p>
      <p>
        Le recomendamos revisar periódicamente este documento. El uso continuo de nuestros servicios
        tras la publicación de cambios implica su aceptación.
      </p>
    </div>

    <!-- 9. Contacto -->
    <div class="section">
      <span class="section-number">09</span>
      <h2>Contacto del responsable</h2>
      <p>Para ejercer sus derechos ARCO o resolver cualquier duda sobre este aviso, contáctenos:</p>
      <div class="contact-box">
        <p><strong>ADNOVA Software Solutions</strong></p>
        <p>Oaxaca de Juárez, Oaxaca, México</p>
        <p>Correo: <a href="mailto:adnovasoftwaresolutions@gmail.com">adnovasoftwaresolutions@gmail.com</a></p>
        <p>WhatsApp: <a href="https://wa.me/525655250768">+52 565 525 0768</a></p>
        <p>Horario de atención: lunes a viernes, 9:00 a 18:00 hrs (tiempo del centro de México)</p>
      </div>
    </div>

  </main>

</footer>

</body>
</html>