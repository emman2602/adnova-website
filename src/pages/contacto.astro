---
import Layout from "../layouts/Layout.astro";
import Contact from "../components/Contact.astro";

const channels = [
  {
    label: "WhatsApp / Teléfono",
    value: "+52 565 525 0768",
    href: "https://wa.me/525655250768?text=Hola%20ADNOVA%2C%20quiero%20un%20diagnóstico%20para%20mi%20negocio",
    note: "Respuesta en menos de 48 horas",
  },
  {
    label: "Correo electrónico",
    value: "contacto@adnovasoftware.com.mx",
    href: "mailto:contacto@adnovasoftware.com.mx",
    note: "Para cotizaciones y dudas generales",
  },
  {
    label: "Ubicación",
    value: "Oaxaca de Juárez, Oaxaca, México",
    href: "https://www.google.com/maps/place/Oaxaca+de+Ju%C3%A1rez,+Oax.",
    note: "Atención local y remota en todo México",
  },
  {
    label: "Horario de atención",
    value: "Lunes a viernes, 9:00–19:00",
    href: null,
    note: "Hora del centro de México",
  },
];

const socials = [
  {
    label: "Instagram",
    handle: "@adnovasoftware",
    href: "https://www.instagram.com/adnovasoftware",
    icon: "instagram",
  },
  {
    label: "TikTok",
    handle: "@adnovasoftwaresolutions",
    href: "https://www.tiktok.com/@adnovasoftwaresolutions",
    icon: "tiktok",
  },
  {
    label: "Facebook",
    handle: "adnovasoftware",
    href: "https://www.facebook.com/adnovasoftware",
    icon: "facebook",
  },
  {
    label: "LinkedIn",
    handle: "ADNOVA Software Solutions",
    href: "https://www.linkedin.com/company/adnovasoftware",
    icon: "linkedin",
  },
];

const icons = {
  instagram:
    '<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="1.8"/><circle cx="12" cy="12" r="4.2" stroke="currentColor" stroke-width="1.8"/><circle cx="17.4" cy="6.6" r="1.1" fill="currentColor"/></svg>',
  tiktok:
    '<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M14 3v10.8a3.3 3.3 0 1 1-2.6-3.23" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><path d="M14 3c.3 2.6 2.1 4.4 4.7 4.7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>',
  facebook:
    '<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M14.5 8.5h2V5.6c-.35-.05-1.55-.15-2.95-.15-2.9 0-4.9 1.77-4.9 5.02v2.53H6v3.3h3.15V21h3.4v-4.7h3.02l.48-3.3h-3.5v-2.2c0-.96.27-1.6 1.95-1.6Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>',
  linkedin:
    '<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="3" width="18" height="18" rx="3" stroke="currentColor" stroke-width="1.8"/><path d="M7.3 10v6.4M7.3 7.6v.02M11.3 16.4V10M11.3 12.6c0-1.5 1-2.6 2.4-2.6 1.5 0 2.3 1 2.3 2.7v3.7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>',
};

const contactPageSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "@id": "https://adnovasoftware.com.mx/contacto#contactpage",
  name: "Contacto | ADNOVA Software Solutions",
  url: "https://adnovasoftware.com.mx/contacto",
  about: {
    "@id": "https://adnovasoftware.com.mx/#business",
  },
};
---

<Layout
  title="Contacto | ADNOVA Software Solutions — Escríbenos"
  description="Todos los canales de contacto de ADNOVA Software Solutions: WhatsApp, correo, ubicación en Oaxaca y redes sociales. Escríbenos y cuéntanos tu proyecto."
  canonical="https://adnovasoftware.com.mx/contacto"
>
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(contactPageSchema)} />

  <main class="contact-page">
    <section class="contact-hero page-shell">
      <span class="eyebrow">Contacto</span>
      <h1>Hablemos por el canal que más te acomode.</h1>
      <p>
        Todos nuestros datos de contacto y redes sociales están aquí. Escríbenos
        directamente o llena el formulario y te respondemos en menos de 48 horas.
      </p>
    </section>

    <section class="channels-section page-shell">
      <div class="section-index reveal">
        <span>01</span>
        <p>Canales directos</p>
      </div>

      <div class="channels-grid">
        {
          channels.map((item, index) => {
            const Tag = item.href ? "a" : "div";
            return (
              <Tag
                class="channel-card stagger-item"
                style={`--i:${index}`}
                href={item.href ?? undefined}
                target={item.href?.startsWith("http") ? "_blank" : undefined}
                rel={item.href?.startsWith("http") ? "noopener noreferrer" : undefined}
              >
                <span class="channel-label">{item.label}</span>
                <strong class="channel-value">{item.value}</strong>
                <span class="channel-note">{item.note}</span>
              </Tag>
            );
          })
        }
      </div>
    </section>

    <section class="social-section page-shell">
      <div class="section-index reveal">
        <span>02</span>
        <p>Síguenos</p>
      </div>

      <div class="social-grid">
        {
          socials.map((item, index) => (
            <a
              href={item.href}
              target="_blank"
              rel="noopener noreferrer"
              class="social-card stagger-item"
              style={`--i:${index}`}
              aria-label={`ADNOVA en ${item.label}`}
            >
              <span class="social-icon" set:html={icons[item.icon]} />
              <span class="social-text">
                <strong>{item.label}</strong>
                <span>{item.handle}</span>
              </span>
              <span class="social-arrow">↗</span>
            </a>
          ))
        }
      </div>
    </section>

    <Contact />
  </main>
</Layout>

<style>
  .contact-page {
    --contact-accent: var(--blue);
    --contact-border: rgba(15, 23, 42, 0.08);

    background: var(--bg);
  }

  .page-shell {
    width: calc(100% - 64px);
    max-width: 1820px;
    margin: 0 auto;
  }

  .contact-hero {
    display: grid;
    gap: 22px;
    max-width: 980px;
    padding: 108px 44px 64px;
  }

  .eyebrow,
  .section-index span {
    width: fit-content;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--contact-accent);
    font-size: 12px;
    line-height: 1;
    font-weight: var(--weight-strong);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .eyebrow::before,
  .section-index span::before {
    content: "";
    width: 8px;
    height: 8px;
    background: currentColor;
  }

  .contact-hero h1 {
    margin: 0;
    color: var(--ink);
    font-size: clamp(40px, 4.7vw, 74px);
    line-height: 1;
    font-weight: var(--weight-display);
    letter-spacing: -0.07em;
  }

  .contact-hero p {
    max-width: 640px;
    margin: 0;
    color: var(--muted);
    font-size: var(--text-body-lg);
    line-height: 1.5;
    font-weight: var(--weight-body);
    letter-spacing: -0.02em;
  }

  .channels-section,
  .social-section {
    display: grid;
    grid-template-columns: 0.26fr 0.74fr;
    gap: 42px;
    padding: 56px 44px;
    border-top: 1px solid var(--contact-border);
  }

  .section-index {
    display: grid;
    align-content: start;
    gap: 10px;
  }

  .section-index p {
    margin: 0;
    color: var(--ink);
    font-size: 15px;
    font-weight: var(--weight-medium);
  }

  .channels-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--contact-border);
  }

  .channel-card {
    display: grid;
    align-content: start;
    gap: 10px;
    padding: 26px;
    background: var(--panel);
    color: var(--ink);
    text-decoration: none;
    transition:
      background 0.25s ease,
      transform 0.25s ease;
  }

  a.channel-card:hover {
    background: white;
    transform: translateY(-3px);
  }

  .channel-label {
    color: var(--contact-accent);
    font-size: 12px;
    font-weight: var(--weight-strong);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .channel-value {
    color: var(--ink);
    font-size: 20px;
    line-height: 1.25;
    font-weight: var(--weight-heading);
    letter-spacing: -0.02em;
    overflow-wrap: anywhere;
  }

  .channel-note {
    color: var(--muted);
    font-size: 13px;
    line-height: 1.4;
  }

  .social-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--contact-border);
  }

  .social-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 22px 26px;
    background: var(--panel);
    color: var(--ink);
    text-decoration: none;
    transition:
      background 0.25s ease,
      transform 0.25s ease;
  }

  .social-card:hover {
    background: white;
    transform: translateY(-3px);
  }

  .social-icon {
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    flex: 0 0 auto;
    background: var(--black);
    color: white;
  }

  .social-icon :global(svg) {
    width: 20px;
    height: 20px;
  }

  .social-text {
    display: grid;
    gap: 2px;
    min-width: 0;
  }

  .social-text strong {
    font-size: 16px;
    font-weight: var(--weight-strong);
  }

  .social-text span {
    color: var(--muted);
    font-size: 13px;
    overflow-wrap: anywhere;
  }

  .social-arrow {
    margin-left: auto;
    color: var(--contact-accent);
    font-size: 20px;
  }

  @media (max-width: 1100px) {
    .channels-section,
    .social-section {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 760px) {
    .page-shell {
      width: 100%;
    }

    .contact-hero {
      padding: 80px 20px 48px;
    }

    .channels-section,
    .social-section {
      padding: 44px 20px;
      gap: 24px;
    }

    .channels-grid,
    .social-grid {
      grid-template-columns: 1fr;
    }
  }
</style>