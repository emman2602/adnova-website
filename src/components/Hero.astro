---

<section id="inicio" class="hero source-container">
  <div class="hero-left">
    <div
  class="hero-image image-slot cut-corner reveal-image"
  style="background-image: url('/images/hero1.webp')"
>
</div>

    <p class="hero-description reveal">
      Desarrollamos sistemas que ayudan a negocios a reducir trabajo manual,
      conectar sus herramientas y operar con más control para enfocarse en
      resolver problemas reales, no repetir las mismas tareas.
    </p>
  </div>

  <div class="hero-right">
    <a href="#contacto" class="hero-announcement reveal">
      <span>◆</span>
      ADNOVA desarrolla sistemas internos para PyMEs mexicanas
      <strong>›</strong>
    </a>

    <h1 class="hero-title reveal">
      Sistemas digitales para negocios que quieren operar mejor.
    </h1>

    <div class="hero-action-zone reveal">
      <div class="hero-rating">
        <div class="avatars">
          <span></span>
          <span></span>
          <span></span>
          <span></span>
        </div>

        <div class="rating-copy">
          <div>◆ ◆ ◆ ◆ ◆ <b>4.9/5</b></div>
          <p>Soluciones tecnológicas para negocios en crecimiento</p>
        </div>
      </div>

      <a href="#contacto" class="hero-cta">
        <span>Agendar diagnóstico</span>
        <strong>↗</strong>
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: calc(100vh - 64px);
    border-left: 1px solid var(--line);
    border-right: 1px solid var(--line);
  }

  .hero-left {
    display: grid;
    grid-template-rows: 1fr auto;
    border-right: 1px solid var(--line);
  }

  .hero-image {
    height: calc(100vh - 240px);
    min-height: 430px;
    max-height: 640px;
    border-bottom: 1px solid var(--line);
  }

  .hero-description {
    min-height: 130px;
    display: flex;
    align-items: center;
    padding: 28px 34px;
    color: var(--muted);
    font-size: clamp(18px, 1.55vw, 24px);
    line-height: 1.35;
    font-weight: 520;
    letter-spacing: -0.03em;
  }

  .hero-right {
    display: flex;
    flex-direction: column;
    padding: 32px 42px 0;
  }

  .hero-announcement {
    width: fit-content;
    max-width: 100%;
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 34px;
    padding: 9px 13px;
    background: var(--black);
    color: white;
    font-size: 14px;
    font-weight: 560;
    line-height: 1.25;
    text-decoration: none;
    transition:
      background 0.25s ease,
      transform 0.25s ease;
  }

  .hero-announcement:hover {
    background: var(--blue);
    transform: translateY(-2px);
  }

  .hero-announcement span {
    display: grid;
    place-items: center;
    flex: 0 0 auto;
    width: 23px;
    height: 23px;
    background: var(--blue);
    color: white;
    font-size: 12px;
  }

  .hero-announcement:hover span {
    background: white;
    color: var(--blue);
  }

  .hero-announcement strong {
    flex: 0 0 auto;
    font-size: 23px;
    line-height: 0;
    font-weight: 400;
  }

  .hero-title {
    max-width: 820px;
    margin: 0;
    color: var(--ink);
    font-size: clamp(46px, 5.2vw, 92px);
    line-height: 0.98;
    font-weight: 650;
    letter-spacing: -0.065em;
  }

  .hero-action-zone {
    margin-top: 92px;
    display: grid;
    gap: 28px;
    align-items: start;
  }

  .hero-rating {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .avatars {
    display: flex;
    flex: 0 0 auto;
  }

  .avatars span {
    width: 34px;
    height: 34px;
    margin-left: -8px;
    border: 2px solid var(--bg);
    border-radius: 50%;
    background: var(--panel);
  }

  .avatars span:first-child {
    margin-left: 0;
  }

  .rating-copy {
    color: var(--ink);
    font-size: 14px;
    font-weight: 560;
  }

  .rating-copy b {
    margin-left: 10px;
    font-weight: 650;
  }

  .rating-copy p {
    margin: 5px 0 0;
    color: var(--muted);
    font-size: 13px;
    line-height: 1.35;
    font-weight: 430;
  }

  .hero-cta {
    width: 100%;
    min-height: 112px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    padding: 0 34px;
    background: var(--black);
    color: white;
    font-size: 22px;
    font-weight: 650;
    line-height: 1;
    text-decoration: none;
    transition:
      transform 0.25s ease,
      background 0.25s ease;
  }

  .hero-cta:hover {
    transform: translateY(-2px);
    background: var(--blue);
  }

  .hero-cta strong {
    font-size: 42px;
    font-weight: 400;
    line-height: 1;
  }

  @media (max-width: 1100px) {
    .hero {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .hero-left {
      border-right: 0;
      border-bottom: 1px solid var(--line);
    }

    .hero-image {
      height: 420px;
      min-height: 420px;
      max-height: none;
    }

    .hero-right {
      min-height: auto;
      padding: 34px;
    }

    .hero-action-zone {
      margin-top: 44px;
    }

    .hero-cta {
      min-height: 84px;
    }
  }

  @media (max-width: 700px) {
    .hero {
      border-left: 0;
      border-right: 0;
    }

    .hero-image {
      height: 300px;
      min-height: 300px;
    }

    .hero-right {
      padding: 28px 20px 0;
    }

    .hero-title {
      font-size: clamp(38px, 11vw, 58px);
      line-height: 1.02;
      font-weight: 620;
      letter-spacing: -0.055em;
    }

    .hero-description {
      min-height: auto;
      padding: 24px 20px;
      font-size: 17px;
    }

    .hero-announcement {
      width: 100%;
      font-size: 12px;
      line-height: 1.35;
    }

    .hero-action-zone {
      margin-top: 34px;
      gap: 22px;
    }

    .hero-rating {
      align-items: flex-start;
      flex-direction: column;
      gap: 12px;
    }

    .hero-cta {
      width: 100%;
      min-height: 64px;
      padding: 0 22px;
      font-size: 16px;
    }

    .hero-cta strong {
      font-size: 28px;
    }
  }

  @media (max-width: 420px) {
    .hero-title {
      font-size: 34px;
    }

    .hero-image {
      height: 270px;
      min-height: 270px;
    }

    .hero-announcement {
      padding: 9px 11px;
    }

    .hero-announcement strong {
      display: none;
    }
  }
</style>