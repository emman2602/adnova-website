---
import Layout from '../layouts/Layout.astro';

import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import TrustSection from '../components/TrustSection.astro';
import About from '../components/About.astro';
import StatsMedia from '../components/StatsMedia.astro';
import Foundation from '../components/Foundation.astro';
import Services from '../components/Services.astro';
import Projects from '../components/Projects.astro';
import Process from '../components/Process.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="ADNOVA® | Desarrollo de software para PyMEs en México"
  description="Desarrollamos software a medida, sistemas administrativos, automatización, dashboards, páginas web e integraciones para PyMEs en México."
  canonical="https://adnovasoftware.com.mx/"
  preloadHero={true}
>
  

  <main>
    <Hero />
    <TrustSection />
    <About />
    <StatsMedia />
    <Foundation />
    <Services />
    <Projects />
    <Process />
    <Contact />
    
  </main>
</Layout>

<script>
  const animatedElements = document.querySelectorAll(
    '.reveal, .reveal-image, .stagger-item, .text-mask'
  );

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, {
    threshold: 0.14,
    rootMargin: '0px 0px -70px 0px'
  });

  animatedElements.forEach((element) => observer.observe(element));
</script>