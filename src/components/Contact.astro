              <a href="mailto:adnovasoftwaresolutions@gmail.com">adnovasoftwaresolutions@gmail.com</a>
            </div>
            <div class="cii">
              <svg viewBox="0 0 18 18" fill="none"><path d="M2 4a1 1 0 011-1h2.5l1.5 3.5L5.5 8a10 10 0 004.5 4.5l1.5-1.5L15 12.5V15a1 1 0 01-1 1C7 16 2 11 2 5V4z" stroke="rgba(255,255,255,0.5)" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <a href="tel:+529512690421">+52 951 269 0421</a>
            </div>
          </div>
        </div>
      </div>

      <div class="contact-form-wrap">
        <h3 class="form-title">Cuéntanos tu proyecto</h3>
        <form class="contact-form" id="contact-form">
          <div class="form-row">
            <div class="form-group">
              <label>Nombre</label>
              <input type="text" name="name" placeholder="Tu nombre" required />
            </div>
            <div class="form-group">
              <label>Correo electrónico</label>
              <input type="email" name="email" placeholder="tu@empresa.com" required />
            </div>
          </div>
          <div class="form-group">
            <label>Empresa</label>
            <input type="text" name="company" placeholder="Nombre de tu empresa" />
          </div>
          <div class="form-group">
            <label>Servicio de interés</label>
            <select name="service">
              <option value="">Selecciona...</option>
              <option>Sistemas empresariales / ERP</option>
              <option>Automatización de procesos</option>
              <option>Integraciones y APIs</option>
              <option>Desarrollo web y móvil</option>
              <option>Mantenimiento y soporte</option>
              <option>Varios servicios</option>
            </select>
          </div>
          <div class="form-group">
            <label>Describe tu proyecto</label>
            <textarea name="message" rows="4" placeholder="¿Qué problema necesitas resolver? ¿Tienes un plazo estimado?" required></textarea>
          </div>
          <button type="submit" class="form-submit" id="submit-btn">
            Enviar solicitud →
          </button>
          <div id="form-success" class="form-success" style="display:none">
            ✓ ¡Recibido! Te escribimos en menos de 48 horas.
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

