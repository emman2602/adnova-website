---

---

<section id="inicio" class="hero source-container">
  <div class="hero-image">
    <img
      src="/images/hero-adnova3.webp"
      alt="Empresa de desarrollo de software revisando un sistema empresarial"
      width="900"
      height="1000"
      fetchpriority="high"
      decoding="async"
    />
  </div>

  <div class="hero-content">
    <a href="#contacto" class="hero-announcement">
      <span>◆</span>
      ADNOVA desarrolla sistemas para empresas mexicanas
      <strong>›</strong>
    </a>

    <h1 class="hero-title" aria-label="Sistemas digitales para negocios que quieren operar mejor.">
      <span>Sistemas digitales</span>
      <span>para negocios que</span>
      <span>quieren operar</span>
      <span>mejor.</span>
    </h1>

    <div class="hero-rating">
      <div class="rating-copy">
        <p>Software que impulsa tu negocio</p>
      </div>
    </div>
  </div>

  <p class="hero-description">
    Desarrollamos software, automatizaciones y sitios web para PyMEs que necesitan
    más orden, control y claridad en su operación.
  </p>

  <div class="hero-cta-area">
    <a href="#contacto" class="hero-cta">
      <span>Solicitar consulturía</span>
      <strong>↗</strong>
    </a>
  </div>
</section>

<style>
  .hero {
    --hero-scroll: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-areas:
      "image content"
      "description cta";
    min-height: calc(100vh - 64px);
    overflow: hidden;
  }

  .hero-image {
    position: relative;
    grid-area: image;
    height: calc(100vh - 220px);
    min-height: 500px;
    max-height: 680px;
    border-bottom: 1px solid var(--line);
    overflow: hidden;
    background: #c9895f;
    opacity: 0;
    clip-path: inset(8% 8% 8% 8%);
    transform: scale(0.985);
    filter: blur(12px);
    animation: heroImageReveal 1.15s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .hero-image::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    z-index: 2;
    width: 28%;
    height: 18%;
    background: var(--bg);
    clip-path: polygon(0 0, 100% 0, 32% 100%, 0 100%);
    pointer-events: none;
    transform: translateY(calc(var(--hero-scroll) * -36px));
    transition: transform 0.12s linear;
    will-change: transform;
    animation: heroDiagonalReveal 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.25s both;
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
    object-position: center;
    transform:
      translateY(calc(var(--hero-scroll) * 42px))
      scale(calc(1 + (var(--hero-scroll) * 0.04)));
    transition: transform 0.12s linear;
    will-change: transform;
    animation: heroPhotoZoom 1.4s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .hero-content {
    grid-area: content;
    display: flex;
    flex-direction: column;
    padding: 34px 42px 28px;
    opacity: calc(1 - (var(--hero-scroll) * 1.15));
    transform: translateY(calc(var(--hero-scroll) * -90px));
    transition:
      opacity 0.12s linear,
      transform 0.12s linear;
    will-change: opacity, transform;
  }

  .hero-announcement {
    width: fit-content;
    max-width: 100%;
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 34px;
    padding: 9px 13px;
    background: var(--black);
    color: white;
    font-size: 14px;
    font-weight: var(--weight-medium);
    line-height: 1.25;
    text-decoration: none;
    opacity: 0;
    transform: translateY(-18px);
    animation: heroFadeDown 0.75s cubic-bezier(0.16, 1, 0.3, 1) 0.25s forwards;
    transition:
      background 0.25s ease,
      color 0.25s ease;
  }

  .hero-announcement:hover {
    background: var(--blue);
  }

  .hero-announcement span {
    display: grid;
    place-items: center;
    flex: 0 0 auto;
    width: 23px;
    height: 23px;
    background: var(--blue);
    color: white;
    font-size: 12px;
    transition:
      background 0.25s ease,
      color 0.25s ease;
  }

  .hero-announcement:hover span {
    background: white;
    color: var(--blue);
  }

  .hero-announcement strong {
    flex: 0 0 auto;
    font-size: 23px;
    line-height: 0;
    font-weight: 400;
  }

  .hero-title {
    max-width: 850px;
    margin: 0;
    color: var(--ink);
    font-size: clamp(46px, 5.2vw, 92px);
    line-height: 0.98;
    font-weight: var(--weight-display);
    letter-spacing: -0.065em;
  }

  .hero-title span {
    display: block;
    opacity: 0;
    transform: translateY(110%) rotate(2deg);
    transform-origin: left bottom;
    filter: blur(8px);
    animation: heroTitleLine 0.95s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .hero-title span:nth-child(1) {
    animation-delay: 0.42s;
  }

  .hero-title span:nth-child(2) {
    animation-delay: 0.52s;
  }

  .hero-title span:nth-child(3) {
    animation-delay: 0.62s;
  }

  .hero-title span:nth-child(4) {
    animation-delay: 0.72s;
  }

  .hero-rating {
    display: flex;
    align-items: center;
    gap: 18px;
    margin-top: auto;
    opacity: 0;
    transform: translateY(18px);
    animation: heroFadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 1s forwards;
  }

  .rating-copy {
    color: var(--ink);
    font-size: 14px;
    font-weight: var(--weight-medium);
  }

  .rating-copy p {
    margin: 6px 0 0;
    color: var(--muted);
    font-size: 20px;
    line-height: 1.35;
    font-weight: var(--weight-body);
  }

  .hero-description {
    grid-area: description;
    min-height: 150px;
    display: flex;
    align-items: center;
    margin: 0;
    padding: 30px 34px;
    color: var(--muted);
    font-size: clamp(18px, 1.55vw, 24px);
    line-height: 1.36;
    font-weight: var(--weight-body);
    letter-spacing: -0.03em;
    opacity: calc(1 - (var(--hero-scroll) * 1.35));
    transform: translateY(calc(var(--hero-scroll) * -52px));
    transition:
      opacity 0.12s linear,
      transform 0.12s linear;
    will-change: opacity, transform;
    animation: heroFadeUp 0.85s cubic-bezier(0.16, 1, 0.3, 1) 1.05s forwards;
  }

  .hero-cta-area {
    grid-area: cta;
    display: flex;
    align-items: stretch;
    padding: 0;
    opacity: calc(1 - (var(--hero-scroll) * 1.4));
    transform: translateY(calc(var(--hero-scroll) * 80px));
    transition:
      opacity 0.12s linear,
      transform 0.12s linear;
    will-change: opacity, transform;
    animation: heroFadeUp 0.85s cubic-bezier(0.16, 1, 0.3, 1) 1.15s forwards;
  }

  .hero-cta {
    width: 100%;
    min-height: 150px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    padding: 0 34px;
    background: var(--black);
    color: white;
    font-size: 22px;
    font-weight: var(--weight-medium);
    line-height: 1;
    text-decoration: none;
    transition:
      background 0.25s ease,
      transform 0.25s ease;
  }

  .hero-cta:hover {
    background: var(--blue);
  }

  .hero-cta strong {
    font-size: 44px;
    font-weight: 400;
    line-height: 1;
    transition: transform 0.25s ease;
  }

  .hero-cta:hover strong {
    transform: translate(6px, -6px);
  }

  @keyframes heroImageReveal {
    from {
      opacity: 0;
      clip-path: inset(8% 8% 8% 8%);
      transform: scale(0.985);
      filter: blur(12px);
    }

    to {
      opacity: 1;
      clip-path: inset(0 0 0 0);
      transform: scale(1);
      filter: blur(0);
    }
  }

  @keyframes heroPhotoZoom {
    from {
      transform: scale(1.08);
    }

    to {
      transform: scale(1);
    }
  }

  @keyframes heroDiagonalReveal {
    from {
      opacity: 0;
      transform: translate(-42px, -42px);
    }

    to {
      opacity: 1;
      transform: translate(0, 0);
    }
  }

  @keyframes heroFadeDown {
    from {
      opacity: 0;
      transform: translateY(-18px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes heroFadeUp {
    from {
      opacity: 0;
      transform: translateY(26px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes heroTitleLine {
    from {
      opacity: 0;
      transform: translateY(110%) rotate(2deg);
      filter: blur(8px);
    }

    to {
      opacity: 1;
      transform: translateY(0) rotate(0);
      filter: blur(0);
    }
  }

  @media (max-width: 1100px) {
    .hero {
      grid-template-columns: 1fr;
      grid-template-areas:
        "image"
        "content"
        "description"
        "cta";
      min-height: auto;
    }

    .hero-image {
      height: 460px;
      min-height: 460px;
      max-height: none;
    }

    .hero-image::before {
      width: 28%;
      height: 16%;
      clip-path: polygon(0 0, 100% 0, 32% 100%, 0 100%);
    }

    .hero-content {
      padding: 44px 34px 34px;
      border-bottom: 1px solid var(--line);
    }

    .hero-title {
      max-width: 900px;
    }

    .hero-rating {
      margin-top: 42px;
    }

    .hero-description {
      min-height: auto;
      padding: 34px;
      border-bottom: 1px solid var(--line);
    }

    .hero-cta {
      min-height: 96px;
    }
  }

  @media (max-width: 700px) {
    .hero-image {
      height: 58vh;
      min-height: 390px;
    }

    .hero-image::before {
      width: 36%;
      height: 13%;
      clip-path: polygon(0 0, 100% 0, 38% 100%, 0 100%);
    }

    .hero-content {
      padding: 36px 20px 30px;
    }

    .hero-announcement {
      width: 100%;
      margin-bottom: 32px;
      padding: 11px 13px;
      font-size: 12px;
      line-height: 1.35;
    }

    .hero-title {
      max-width: 100%;
      font-size: clamp(54px, 14vw, 82px);
      line-height: 0.96;
      letter-spacing: -0.07em;
    }

    .hero-rating {
      align-items: flex-start;
      flex-direction: column;
      gap: 14px;
      margin-top: 34px;
    }

    .rating-copy {
      font-size: 15px;
    }

    .rating-copy p {
      max-width: 340px;
      font-size: 14px;
    }

    .hero-description {
      padding: 32px 20px;
      font-size: 20px;
      line-height: 1.45;
      letter-spacing: -0.035em;
    }

    .hero-cta-area {
      padding: 0 20px 40px;
      background: var(--bg);
    }

    .hero-cta {
      min-height: 86px;
      padding: 0 24px;
      font-size: 19px;
    }

    .hero-cta strong {
      font-size: 34px;
    }
  }

  @media (max-width: 420px) {
    .hero-image {
      height: 430px;
      min-height: 430px;
    }

    .hero-image::before {
      width: 42%;
      height: 12%;
    }

    .hero-content {
      padding-top: 32px;
    }

    .hero-title {
      font-size: clamp(48px, 13vw, 68px);
    }

    .hero-announcement strong {
      display: none;
    }

    .hero-description {
      font-size: 18px;
    }

    .hero-cta {
      min-height: 76px;
      font-size: 17px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-image,
    .hero-image::before,
    .hero-image img,
    .hero-announcement,
    .hero-title span,
    .hero-rating,
    .hero-description,
    .hero-cta-area {
      opacity: 1;
      transform: none;
      filter: none;
      animation: none;
      transition: none;
    }
  }
</style>

<script>
  const hero = document.querySelector(".hero");

  function clamp(value, min, max) {
    return Math.min(Math.max(value, min), max);
  }

  function updateHeroScroll() {
    if (!hero) return;

    const heroHeight = hero.offsetHeight || 1;
    const scrollY = window.scrollY;
    const progress = clamp(scrollY / (heroHeight * 0.75), 0, 1);

    hero.style.setProperty("--hero-scroll", String(progress));
  }

  updateHeroScroll();

  let ticking = false;

  window.addEventListener(
    "scroll",
    () => {
      if (ticking) return;

      ticking = true;

      requestAnimationFrame(() => {
        updateHeroScroll();
        ticking = false;
      });
    },
    { passive: true }
  );

  window.addEventListener("resize", updateHeroScroll);
</script>