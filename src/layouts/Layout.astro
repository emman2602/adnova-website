---
import '../styles/source-theme.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'ADNOVA® | Software a medida para PyMEs',
  description = 'ADNOVA diseña software a medida, automatización, dashboards e integraciones para PyMEs en México.'
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_MX" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="icon" type="image/png" href="/favicon.png?v=3" />
<link rel="shortcut icon" type="image/png" href="/favicon.png?v=3" />
<link rel="apple-touch-icon" href="/favicon.png?v=3" />

    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <slot />
  </body>
</html>