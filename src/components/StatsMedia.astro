---
---

<section class="stats-media source-container reveal">
  <div class="stats-grid">
    <article>
      <strong>4.9/5</strong>
      <p>satisfacción esperada del cliente</p>
    </article>

    <article>
      <strong>50+</strong>
      <p>procesos que pueden automatizarse</p>
    </article>

    <article>
      <strong>40%</strong>
      <p>reducción estimada de trabajo manual</p>
    </article>

    <article>
      <strong>12+</strong>
      <p>tipos de sistemas que podemos construir</p>
    </article>
  </div>

  <div class="video-slot">
  <video autoplay muted loop playsinline preload="metadata">
    <source src="/videos/programador_escribiendo.mp4" type="video/mp4" />
    Tu navegador no soporta video HTML5.
  </video>
</div>
</section>

<style>
  .stats-media {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-left: 1px solid var(--line);
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .stats-grid article {
    min-height: 260px;
    padding: 34px;
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    transition:
      transform 0.35s cubic-bezier(.16, 1, .3, 1),
      background 0.35s ease;
  }

  .stats-grid article:hover {
    transform: translateY(-4px);
    background: #ffffff;
  }

  .stats-grid article:nth-child(2),
  .stats-grid article:nth-child(4) {
    border-right: 0;
  }

  .stats-grid article:nth-child(3),
  .stats-grid article:nth-child(4) {
    border-bottom: 0;
  }

  .stats-grid strong {
    display: block;
    font-size: clamp(58px, 5.4vw, 96px);
    line-height: 0.9;
    font-weight: 800;
    letter-spacing: -0.08em;
  }

  .stats-grid p {
    margin: 74px 0 0;
    color: var(--muted);
    font-size: 21px;
    line-height: 1.25;
    font-weight: 500;
    letter-spacing: -0.04em;
  }

  .video-slot {
  position: relative;
  min-height: 520px;
  overflow: hidden;
  background: var(--panel);
}


  
  .video-slot video {
  width: 100%;
  height: 100%;
  min-height: 520px;
  display: block;
  object-fit: cover;
}


  .video-slot button {
    position: absolute;
    display: grid;
    place-items: center;
    width: 92px;
    height: 92px;
    border: 0;
    border-radius: 50%;
    background: rgba(244, 241, 232, 0.74);
    color: var(--ink);
    font-size: 34px;
    cursor: pointer;
  }

  @media (max-width: 1100px) {
    .stats-media {
      display: block;
    }
  }

  @media (max-width: 700px) {
    .stats-grid {
      grid-template-columns: 1fr;
    }

    .stats-grid article {
      border-right: 0 !important;
      border-bottom: 1px solid var(--line) !important;
    }

    .video-slot {
      min-height: 360px;
    }
  }
</style>