---
const technologies = [
  'Laravel',
  'PHP',
  'Java',
  'Spring Boot',
  'PostgreSQL',
  'MySQL',
  'APIs REST',
  'Svelte',
  'React',
  'Astro',
  'JavaScript',
  'TypeScript',
  'HTML',
  'CSS',
  'GitHub'
];

const repeatedTechnologies = [...technologies, ...technologies];
---

<section class="tech-section source-container reveal">
  <div class="tech-heading">
    <span>Tecnologías</span>

    <h2>Herramientas modernas para construir soluciones digitales confiables.</h2>

    <p>
      Trabajamos con tecnologías actuales para desarrollar sitios web, sistemas
      administrativos, plataformas digitales e integraciones adaptadas a cada proyecto.
    </p>
  </div>

  <div class="tech-marquee" aria-label="Tecnologías con las que trabaja ADNOVA">
    <div class="tech-track">
      {
        repeatedTechnologies.map((tech) => (
          <span class="tech-chip">{tech}</span>
        ))
      }
    </div>
  </div>
</section>

<style>
  .tech-section {
    padding: 76px 34px;
    border-left: 1px solid var(--line);
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    background: var(--black);
    color: white;
    overflow: hidden;
  }

  .tech-heading {
    display: grid;
    grid-template-columns: 0.52fr 0.48fr;
    gap: 24px 80px;
    align-items: end;
    margin-bottom: 46px;
  }

  .tech-heading > span {
    grid-column: 1 / -1;
    width: fit-content;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: #c6d5ff;
    font-size: 12px;
    line-height: 1;
    font-weight: var(--weight-strong);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .tech-heading > span::before {
    content: "";
    width: 8px;
    height: 8px;
    background: currentColor;
  }

  .tech-heading h2 {
    max-width: 920px;
    margin: 0;
    color: white;
    font-size: clamp(36px, 4vw, 68px);
    line-height: 1;
    font-weight: var(--weight-heading);
    letter-spacing: -0.065em;
  }

  .tech-heading p {
    max-width: 580px;
    margin: 0;
    color: rgba(255, 255, 255, 0.68);
    font-size: var(--text-body-lg);
    line-height: 1.45;
    font-weight: var(--weight-body);
    letter-spacing: -0.02em;
  }

  .tech-marquee {
    position: relative;
    width: 100%;
    overflow: hidden;
    padding: 4px 0;
  }

  .tech-marquee::before,
  .tech-marquee::after {
    content: "";
    position: absolute;
    top: 0;
    z-index: 2;
    width: 120px;
    height: 100%;
    pointer-events: none;
  }

  .tech-marquee::before {
    left: 0;
    background: linear-gradient(to right, var(--black), transparent);
  }

  .tech-marquee::after {
    right: 0;
    background: linear-gradient(to left, var(--black), transparent);
  }

  .tech-track {
    width: max-content;
    display: flex;
    gap: 10px;
    animation: tech-scroll 34s linear infinite;
  }

  .tech-marquee:hover .tech-track {
    animation-play-state: paused;
  }

  .tech-chip {
    min-height: 48px;
    display: inline-flex;
    align-items: center;
    padding: 0 20px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.06);
    color: white;
    font-size: 15px;
    line-height: 1;
    font-weight: var(--weight-medium);
    letter-spacing: -0.02em;
    white-space: nowrap;
  }

  @keyframes tech-scroll {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(-50%);
    }
  }

  @media (max-width: 1100px) {
    .tech-heading {
      grid-template-columns: 1fr;
      gap: 22px;
    }
  }

  @media (max-width: 700px) {
    .tech-section {
      padding: 64px 20px;
      border-left: 0;
      border-right: 0;
    }

    .tech-heading {
      margin-bottom: 36px;
    }

    .tech-heading h2 {
      font-size: clamp(34px, 9vw, 48px);
      line-height: 1.02;
    }

    .tech-heading p {
      font-size: 17px;
    }

    .tech-marquee::before,
    .tech-marquee::after {
      width: 54px;
    }

    .tech-track {
      animation-duration: 28s;
    }

    .tech-chip {
      min-height: 44px;
      padding: 0 16px;
      font-size: 14px;
    }
  }
</style>