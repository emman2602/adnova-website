<section id="contacto" class="contact-section source-container">
  <div class="contact-inner">
    <div class="contact-copy reveal">
      <span class="contact-kicker">Contacto</span>

      <h2>
        Hablemos de cómo mejorar tu negocio.
      </h2>

      <p>
        Cuéntanos qué necesitas resolver. Podemos ayudarte con sistemas administrativos,
        automatización, páginas web, dashboards o plataformas a medida.
      </p>

      <div class="contact-actions">
        <a
          href="https://wa.me/529512690421?text=Hola%20ADNOVA%2C%20quiero%20un%20diagnóstico%20para%20mi%20negocio"
          target="_blank"
          class="whatsapp-link"
        >
          Escribir por WhatsApp
          <span>↗</span>
        </a>

        <a href="mailto:adnovasoftwaresolutions@gmail.com" class="mail-link">
          adnovasoftwaresolutions@gmail.com
        </a>
      </div>

      <div class="contact-meta">
        <div>
          <span>Ubicación</span>
          <strong>Oaxaca, México</strong>
        </div>

        <div>
          <span>Respuesta</span>
          <strong>Menos de 48 horas</strong>
        </div>

        <div>
          <span>Atención</span>
          <strong>Local y remota</strong>
        </div>
      </div>
    </div>

    <form class="contact-form reveal" id="contact-form">
      <div class="form-head">
        <span>Solicitud de diagnóstico</span>
        <p>Déjanos tus datos y te contactamos.</p>
      </div>

      <label>
        Nombre
        <input type="text" name="name" placeholder="Tu nombre" required />
      </label>

      <label>
        Correo
        <input type="email" name="email" placeholder="tu@empresa.com" required />
      </label>

      <label>
        Servicio de interés
        <select name="service">
          <option value="">Selecciona una opción</option>
          <option>Sistema administrativo / ERP</option>
          <option>Punto de venta e inventario</option>
          <option>Dashboard y reportes</option>
          <option>Automatización de procesos</option>
          <option>Integraciones / APIs</option>
          <option>Página web / presencia digital</option>
        </select>
      </label>

      <label>
        Mensaje
        <textarea
          name="message"
          rows="4"
          placeholder="Cuéntanos brevemente qué necesitas resolver..."
          required
        ></textarea>
      </label>

      <button type="submit" id="submit-btn">
        Enviar solicitud
        <span>↗</span>
      </button>

      <p id="form-success" class="form-success">
        Solicitud enviada. Te responderemos lo antes posible.
      </p>
    </form>
  </div>
</section>

<style>
  .contact-section {
    margin-top: 96px;
    padding: 34px;
    border-left: 1px solid var(--line);
    border-right: 1px solid var(--line);
    background: var(--bg);
  }

  .contact-inner {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(360px, 520px);
    gap: 56px;
    align-items: center;
    padding: 58px;
    background: var(--black);
    color: white;
  }

  .contact-copy {
    max-width: 720px;
  }

  .contact-kicker {
    display: inline-block;
    margin-bottom: 20px;
    color: #9fb6ff;
    font-size: 13px;
    font-weight: 720;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .contact-copy h2 {
    max-width: 760px;
    margin: 0;
    font-size: clamp(42px, 5vw, 82px);
    line-height: 0.98;
    font-weight: 650;
    letter-spacing: -0.075em;
  }

  .contact-copy p {
    max-width: 620px;
    margin: 26px 0 0;
    color: rgba(255, 255, 255, 0.68);
    font-size: clamp(17px, 1.45vw, 21px);
    line-height: 1.45;
    font-weight: 430;
    letter-spacing: -0.025em;
  }

  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    align-items: center;
    margin-top: 34px;
  }

  .whatsapp-link {
    min-height: 54px;
    display: inline-flex;
    align-items: center;
    gap: 18px;
    padding: 0 20px;
    background: var(--blue);
    color: white;
    font-size: 15px;
    font-weight: 650;
    text-decoration: none;
    transition:
      background 0.25s ease,
      transform 0.25s ease;
  }

  .whatsapp-link:hover {
    background: var(--blue-dark);
    transform: translateY(-3px);
  }

  .whatsapp-link span {
    font-size: 22px;
  }

  .mail-link {
    color: rgba(255, 255, 255, 0.72);
    font-size: 15px;
    font-weight: 520;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .mail-link:hover {
    color: white;
  }

  .contact-meta {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    margin-top: 46px;
    background: rgba(255, 255, 255, 0.14);
  }

  .contact-meta div {
    padding: 20px;
    background: var(--black);
  }

  .contact-meta span {
    display: block;
    color: rgba(255, 255, 255, 0.46);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .contact-meta strong {
    display: block;
    margin-top: 10px;
    color: white;
    font-size: 15px;
    line-height: 1.3;
    font-weight: 620;
  }

  .contact-form {
    display: grid;
    gap: 16px;
    padding: 26px;
    background: #fbfaf4;
    color: var(--ink);
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.18);
  }

  .form-head {
    padding-bottom: 16px;
    border-bottom: 1px solid var(--line);
  }

  .form-head span {
    display: block;
    color: var(--blue);
    font-size: 12px;
    font-weight: 720;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .form-head p {
    margin: 8px 0 0;
    color: var(--muted);
    font-size: 15px;
    line-height: 1.4;
  }

  .contact-form label {
    display: grid;
    gap: 8px;
    color: var(--ink);
    font-size: 13px;
    font-weight: 650;
  }

  .contact-form input,
  .contact-form select,
  .contact-form textarea {
    width: 100%;
    border: 1px solid var(--line);
    border-radius: 0;
    background: white;
    color: var(--ink);
    padding: 13px 14px;
    font: inherit;
    font-size: 14px;
    font-weight: 430;
    outline: none;
    transition:
      border-color 0.2s ease,
      background 0.2s ease,
      transform 0.2s ease;
  }

  .contact-form input::placeholder,
  .contact-form textarea::placeholder {
    color: rgba(95, 92, 85, 0.58);
  }

  .contact-form input:focus,
  .contact-form select:focus,
  .contact-form textarea:focus {
    border-color: var(--blue);
    background: #ffffff;
    transform: translateY(-1px);
  }

  .contact-form textarea {
    min-height: 116px;
    resize: vertical;
    line-height: 1.45;
  }

  .contact-form button {
    min-height: 54px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border: 0;
    background: var(--black);
    color: white;
    padding: 0 18px;
    font-size: 15px;
    font-weight: 650;
    cursor: pointer;
    transition:
      background 0.25s ease,
      transform 0.25s ease;
  }

  .contact-form button:hover {
    background: var(--blue);
    transform: translateY(-2px);
  }

  .contact-form button span {
    font-size: 22px;
    line-height: 1;
  }

  .contact-form button:disabled {
    cursor: wait;
    opacity: 0.72;
  }

  .form-success {
    display: none;
    margin: 0;
    padding: 14px;
    background: #e8efff;
    color: var(--blue-dark);
    font-size: 14px;
    font-weight: 650;
  }

  @media (max-width: 1100px) {
    .contact-inner {
      grid-template-columns: 1fr;
      padding: 44px;
    }

    .contact-form {
      max-width: 560px;
      width: 100%;
    }
  }

  @media (max-width: 760px) {
    .contact-section {
      margin-top: 70px;
      padding: 0;
      border-left: 0;
      border-right: 0;
    }

    .contact-inner {
      padding: 42px 20px;
      gap: 36px;
    }

    .contact-copy h2 {
      font-size: clamp(38px, 11vw, 58px);
      line-height: 1;
    }

    .contact-actions {
      align-items: stretch;
      flex-direction: column;
    }

    .whatsapp-link {
      justify-content: space-between;
    }

    .mail-link {
      word-break: break-word;
    }

    .contact-meta {
      grid-template-columns: 1fr;
    }

    .contact-form {
      max-width: none;
      padding: 20px;
    }
  }
</style>

<script>
  const form = document.getElementById('contact-form');
  const successMsg = document.getElementById('form-success');
  const submitBtn = document.getElementById('submit-btn');

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();

    if (!submitBtn || !(form instanceof HTMLFormElement)) return;

    submitBtn.setAttribute('disabled', 'true');
    submitBtn.innerHTML = 'Enviando... <span>↗</span>';

    const formData = new FormData(form);

    try {
      const response = await fetch('https://formspree.io/f/xgorqnpy', {
        method: 'POST',
        body: formData,
        headers: {
          Accept: 'application/json'
        }
      });

      if (response.ok) {
        form.reset();

        if (successMsg) {
          successMsg.style.display = 'block';
        }

        submitBtn.innerHTML = 'Enviar solicitud <span>↗</span>';
        submitBtn.removeAttribute('disabled');
      } else {
        throw new Error('No se pudo enviar');
      }
    } catch (error) {
      alert('No se pudo enviar el formulario. Intenta escribirnos por WhatsApp.');
      submitBtn.innerHTML = 'Enviar solicitud <span>↗</span>';
      submitBtn.removeAttribute('disabled');
    }
  });
</script>