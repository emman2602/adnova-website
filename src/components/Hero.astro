---
---

<section id="inicio" class="hero source-container">
  <div class="hero-image cut-corner reveal-image">
  <img
    src="/images/hero-adnova.webp"
    alt="Empresa de desarrollo de software revisando un sistema empresarial"
    width="900"
    height="1000"
    fetchpriority="high"
    decoding="async"
  />
</div>

  <div class="hero-content">
    <a href="#contacto" class="hero-announcement reveal">
      <span>◆</span>
      ADNOVA desarrolla sistemas internos para PyMEs mexicanas
      <strong>›</strong>
    </a>

    <h1 class="hero-title reveal">
      Sistemas digitales para negocios que quieren operar mejor.
    </h1>

    <div class="hero-rating reveal">
      <div class="avatars">
        <span></span>
        <span></span>
        <span></span>
        <span></span>
      </div>

      <div class="rating-copy">
        <div>◆ ◆ ◆ ◆ ◆ <b>4.9/5</b></div>
        <p>Soluciones tecnológicas para negocios en crecimiento</p>
      </div>
    </div>
  </div>

  <p class="hero-description reveal">
    Desarrollamos sistemas que ayudan a negocios a reducir trabajo manual,
    conectar sus herramientas y operar con más control para enfocarse en resolver
    problemas reales, no repetir las mismas tareas.
  </p>

  <div class="hero-cta-area reveal">
    <a href="#contacto" class="hero-cta">
      <span>Agendar diagnóstico</span>
      <strong>↗</strong>
    </a>
  </div>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-areas:
      "image content"
      "description cta";
    min-height: calc(100vh - 64px);
    border-left: 1px solid var(--line);
    border-right: 1px solid var(--line);
  }

  .hero-image {
  grid-area: image;
  height: calc(100vh - 220px);
  min-height: 500px;
  max-height: 680px;
  border-right: 1px solid var(--line);
  border-bottom: 1px solid var(--line);
  overflow: hidden;
  background: var(--panel);
}

.hero-image img {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
  object-position: center;
}

  .hero-content {
    grid-area: content;
    display: flex;
    flex-direction: column;
    padding: 34px 42px 28px;
  }

  .hero-announcement {
    width: fit-content;
    max-width: 100%;
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 34px;
    padding: 9px 13px;
    background: var(--black);
    color: white;
    font-size: 14px;
    font-weight: var(--weight-medium);
    line-height: 1.25;
    text-decoration: none;
    transition:
      background 0.25s ease,
      transform 0.25s ease;
  }

  .hero-announcement:hover {
    background: var(--blue);
    transform: translateY(-2px);
  }

  .hero-announcement span {
    display: grid;
    place-items: center;
    flex: 0 0 auto;
    width: 23px;
    height: 23px;
    background: var(--blue);
    color: white;
    font-size: 12px;
  }

  .hero-announcement:hover span {
    background: white;
    color: var(--blue);
  }

  .hero-announcement strong {
    flex: 0 0 auto;
    font-size: 23px;
    line-height: 0;
    font-weight: 400;
  }

  .hero-title {
    max-width: 850px;
    margin: 0;
    color: var(--ink);
    font-size: clamp(46px, 5.2vw, 92px);
    line-height: 0.98;
    font-weight: var(--weight-display);
    letter-spacing: -0.065em;
  }

  .hero-rating {
    display: flex;
    align-items: center;
    gap: 18px;
    margin-top: auto;
  }

  .avatars {
    display: flex;
    flex: 0 0 auto;
  }

  .avatars span {
    width: 36px;
    height: 36px;
    margin-left: -8px;
    border: 2px solid var(--bg);
    border-radius: 50%;
    background: var(--panel);
  }

  .avatars span:first-child {
    margin-left: 0;
  }

  .rating-copy {
    color: var(--ink);
    font-size: 14px;
    font-weight: var(--weight-medium);
  }

  .rating-copy b {
    margin-left: 10px;
    font-weight: var(--weight-strong);
  }

  .rating-copy p {
    margin: 6px 0 0;
    color: var(--muted);
    font-size: 13px;
    line-height: 1.35;
    font-weight: var(--weight-body);
  }

  .hero-description {
    grid-area: description;
    min-height: 150px;
    display: flex;
    align-items: center;
    margin: 0;
    padding: 30px 34px;
    border-right: 1px solid var(--line);
    color: var(--muted);
    font-size: clamp(18px, 1.55vw, 24px);
    line-height: 1.36;
    font-weight: var(--weight-body);
    letter-spacing: -0.03em;
  }

  .hero-cta-area {
    grid-area: cta;
    display: flex;
    align-items: stretch;
    padding: 0;
  }

  .hero-cta {
    width: 100%;
    min-height: 150px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    padding: 0 34px;
    background: var(--black);
    color: white;
    font-size: 22px;
    font-weight: var(--weight-medium);
    line-height: 1;
    text-decoration: none;
    transition:
      transform 0.25s ease,
      background 0.25s ease;
  }

  .hero-cta:hover {
    background: var(--blue);
  }

  .hero-cta strong {
    font-size: 44px;
    font-weight: 400;
    line-height: 1;
  }

  @media (max-width: 1100px) {
    .hero {
      grid-template-columns: 1fr;
      grid-template-areas:
        "image"
        "content"
        "description"
        "cta";
      min-height: auto;
      border-left: 0;
      border-right: 0;
    }

    .hero-image {
      height: 460px;
      min-height: 460px;
      max-height: none;
      border-right: 0;
    }

    .hero-content {
      padding: 44px 34px 34px;
      border-bottom: 1px solid var(--line);
    }

    .hero-title {
      max-width: 900px;
    }

    .hero-rating {
      margin-top: 42px;
    }

    .hero-description {
      min-height: auto;
      padding: 34px;
      border-right: 0;
      border-bottom: 1px solid var(--line);
    }

    .hero-cta {
      min-height: 96px;
    }
  }

  @media (max-width: 700px) {
    .hero-image {
      height: 58vh;
      min-height: 390px;
      border-bottom: 1px solid var(--line);
    }

    .hero-content {
      padding: 36px 20px 30px;
    }

    .hero-announcement {
      width: 100%;
      margin-bottom: 32px;
      padding: 11px 13px;
      font-size: 12px;
      line-height: 1.35;
    }

    .hero-title {
      max-width: 100%;
      font-size: clamp(54px, 14vw, 82px);
      line-height: 0.96;
      letter-spacing: -0.07em;
    }

    .hero-rating {
      align-items: flex-start;
      flex-direction: column;
      gap: 14px;
      margin-top: 34px;
    }

    .avatars span {
      width: 36px;
      height: 36px;
    }

    .rating-copy {
      font-size: 15px;
    }

    .rating-copy p {
      max-width: 340px;
      font-size: 14px;
    }

    .hero-description {
      padding: 32px 20px;
      font-size: 20px;
      line-height: 1.45;
      letter-spacing: -0.035em;
    }

    .hero-cta-area {
      padding: 0 20px 40px;
      background: var(--bg);
    }

    .hero-cta {
      min-height: 86px;
      padding: 0 24px;
      font-size: 19px;
    }

    .hero-cta strong {
      font-size: 34px;
    }
  }

  @media (max-width: 420px) {
    .hero-image {
      height: 430px;
      min-height: 430px;
    }

    .hero-content {
      padding-top: 32px;
    }

    .hero-title {
      font-size: clamp(48px, 13vw, 68px);
    }

    .hero-announcement strong {
      display: none;
    }

    .hero-description {
      font-size: 18px;
    }

    .hero-cta {
      min-height: 76px;
      font-size: 17px;
    }
  }
</style>