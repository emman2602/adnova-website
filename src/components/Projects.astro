---
---
<section id="proyectos" class="projects">
  <div class="container">
    <div class="section-header reveal">
      <div class="stag"><span class="stag-line"></span>Proyectos de referencia</div>
      <h2 class="stitle">Ejemplos de lo que <em>podemos construir</em></h2>
      <p class="ssub">Casos reales de sistemas que desarrollamos para distintos sectores. Cada uno fue diseñado a la medida del cliente.</p>
    </div>

    <div class="projects-grid">

      <!-- PROJECT 1: Restaurant POS -->
      <div class="project-card reveal">
        <div class="pc-mockup">
          <div class="pm-bar">
            <span class="dot r"></span><span class="dot y"></span><span class="dot g"></span>
            <span class="pm-tag">Sistema de Restaurante · Punto de Venta</span>
          </div>
          <div class="pm-body pm-resto">
            <div class="pos-left">
              <div class="pos-cats">
                <button class="pcat active">Entradas</button>
                <button class="pcat">Platos fuertes</button>
                <button class="pcat">Bebidas</button>
                <button class="pcat">Postres</button>
              </div>
              <div class="pos-items">
                <div class="pos-item">
                  <div class="pi-info"><span class="pi-name">Tacos de arrachera</span><span class="pi-price">$185</span></div>
                  <button class="pi-add">+</button>
                </div>
                <div class="pos-item">
                  <div class="pi-info"><span class="pi-name">Quesadillas</span><span class="pi-price">$120</span></div>
                  <button class="pi-add">+</button>
                </div>
                <div class="pos-item">
                  <div class="pi-info"><span class="pi-name">Guacamole</span><span class="pi-price">$95</span></div>
                  <button class="pi-add">+</button>
                </div>
              </div>
            </div>
            <div class="pos-right">
              <div class="pos-mesa">Mesa 4 · 3 comensales</div>
              <div class="pos-ticket">
                <div class="pt-row"><span>2x Tacos arrachera</span><span>$370</span></div>
                <div class="pt-row"><span>1x Guacamole</span><span>$95</span></div>
                <div class="pt-row"><span>2x Agua mineral</span><span>$60</span></div>
                <div class="pt-div"></div>
                <div class="pt-row total"><span>Total</span><span>$525</span></div>
              </div>
              <button class="pos-cobrar">Cobrar $525</button>
            </div>
          </div>
        </div>
        <div class="pc-info">
          <div class="pc-sector">Restaurantes & Food Service</div>
          <h3 class="pc-title">Sistema de Punto de Venta para Restaurante</h3>
          <div class="pc-case">
            <div class="case-block">
              <span class="cb-label problem">Problema</span>
              <p>El restaurante usaba papel y Excel para gestionar pedidos, generando errores en órdenes, cuentas incorrectas y sin control real de inventario.</p>
            </div>
            <div class="case-block">
              <span class="cb-label solution">Solución</span>
              <p>Sistema de POS con gestión de mesas, comandas digitales en cocina, control de inventario en tiempo real y reportes de ventas por turno, mesero y producto.</p>
            </div>
          </div>
          <div class="pc-tags">
            <span>POS</span><span>Inventario</span><span>Cocina digital</span><span>Reportes</span>
          </div>
        </div>
      </div>

      <!-- PROJECT 2: ERP Distribuidora -->
      <div class="project-card reveal delay-1">
        <div class="pc-mockup">
          <div class="pm-bar">
            <span class="dot r"></span><span class="dot y"></span><span class="dot g"></span>
            <span class="pm-tag">ERP Distribuidora · Módulo de Compras</span>
          </div>
          <div class="pm-body pm-erp">
            <div class="erp-sidebar">
              <div class="es-item active">Dashboard</div>
              <div class="es-item">Compras</div>
              <div class="es-item hl">Inventario</div>
              <div class="es-item">Ventas</div>
              <div class="es-item">Proveedores</div>
              <div class="es-item">Reportes</div>
            </div>
            <div class="erp-main">
              <div class="erp-kpis">
                <div class="ek"><span class="ek-n">$4.2M</span><span class="ek-l">Compras mes</span></div>
                <div class="ek"><span class="ek-n">847</span><span class="ek-l">SKUs activos</span></div>
                <div class="ek alert"><span class="ek-n">12</span><span class="ek-l">Bajo stock</span></div>
              </div>
              <div class="erp-table">
                <div class="et-head">
                  <span>Proveedor</span><span>Monto</span><span>Estado</span>
                </div>
                <div class="et-row"><span>Distribuidora MX</span><span>$42,000</span><span class="badge-s green">Pagado</span></div>
                <div class="et-row"><span>Importaciones SA</span><span>$18,500</span><span class="badge-s yellow">Pendiente</span></div>
                <div class="et-row"><span>Logística Norte</span><span>$9,200</span><span class="badge-s blue">En tránsito</span></div>
              </div>
            </div>
          </div>
        </div>
        <div class="pc-info">
          <div class="pc-sector">Distribución & Logística</div>
          <h3 class="pc-title">ERP para Distribuidora con Múltiples Almacenes</h3>
          <div class="pc-case">
            <div class="case-block">
              <span class="cb-label problem">Problema</span>
              <p>La empresa operaba con hojas de cálculo desconectadas entre sus 3 almacenes. Sin trazabilidad de productos ni visibilidad de cuentas por pagar en tiempo real.</p>
            </div>
            <div class="case-block">
              <span class="cb-label solution">Solución</span>
              <p>ERP con módulos de compras, inventario multi-almacén, cuentas por pagar, recepción de mercancía y reportes ejecutivos con alertas automáticas de stock mínimo.</p>
            </div>
          </div>
          <div class="pc-tags">
            <span>ERP</span><span>Multi-almacén</span><span>Proveedores</span><span>Alertas</span>
          </div>
        </div>
      </div>

      <!-- PROJECT 3: Operations Dashboard -->
      <div class="project-card reveal delay-2">
        <div class="pc-mockup">
          <div class="pm-bar">
            <span class="dot r"></span><span class="dot y"></span><span class="dot g"></span>
            <span class="pm-tag">Dashboard Operativo · Empresa de Servicios</span>
          </div>
          <div class="pm-body pm-dash">
            <div class="d-header">
              <span class="d-title">Operaciones · Julio 2025</span>
              <div class="d-filters">
                <span class="df active">Semana</span>
                <span class="df">Mes</span>
                <span class="df">Año</span>
              </div>
            </div>
            <div class="d-metrics">
              <div class="dm green"><span class="dm-n">98.2%</span><span class="dm-l">Uptime SLA</span></div>
              <div class="dm blue"><span class="dm-n">2.4h</span><span class="dm-l">T. respuesta prom.</span></div>
              <div class="dm yellow"><span class="dm-n">14</span><span class="dm-l">Tickets abiertos</span></div>
            </div>
            <div class="d-chart">
              <div class="dc-label">Tickets resueltos por día</div>
              <div class="dc-line">
                <svg viewBox="0 0 280 60" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <polyline points="0,45 40,38 80,42 120,25 160,30 200,18 240,22 280,10" stroke="#3b5bd7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                  <polyline points="0,45 40,38 80,42 120,25 160,30 200,18 240,22 280,10 280,60 0,60" fill="rgba(59,91,215,0.08)"/>
                  <circle cx="280" cy="10" r="3" fill="#3b5bd7"/>
                </svg>
              </div>
            </div>
            <div class="d-tickets">
              <div class="dt-row"><span class="dt-id">#1042</span><span class="dt-desc">Falla en módulo de facturación</span><span class="badge-s red">Urgente</span></div>
              <div class="dt-row"><span class="dt-id">#1041</span><span class="dt-desc">Actualización de permisos de usuario</span><span class="badge-s blue">En proceso</span></div>
              <div class="dt-row"><span class="dt-id">#1040</span><span class="dt-desc">Reporte mensual de ventas</span><span class="badge-s green">Resuelto</span></div>
            </div>
          </div>
        </div>
        <div class="pc-info">
          <div class="pc-sector">Empresas de Servicios</div>
          <h3 class="pc-title">Dashboard de Operaciones y Soporte</h3>
          <div class="pc-case">
            <div class="case-block">
              <span class="cb-label problem">Problema</span>
              <p>El equipo de soporte no tenía visibilidad centralizada de tickets, SLAs y rendimiento del equipo. Los reportes se hacían manualmente cada semana.</p>
            </div>
            <div class="case-block">
              <span class="cb-label solution">Solución</span>
              <p>Dashboard en tiempo real con gestión de tickets, seguimiento de SLAs, métricas de rendimiento por agente y reportes automáticos para dirección.</p>
            </div>
          </div>
          <div class="pc-tags">
            <span>Dashboard</span><span>Tickets</span><span>SLA</span><span>Tiempo real</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
.projects { padding: 7rem 2rem; background: white; }
.container { max-width: 1280px; margin: 0 auto; }
.section-header { text-align: center; margin-bottom: 4rem; }
.stag { display: inline-flex; align-items: center; gap: 0.7rem; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--blue); margin-bottom: 1rem; }
.stag-line { display: block; width: 22px; height: 2px; background: var(--blue); border-radius: 1px; }
.stitle { font-family: 'Syne', sans-serif; font-size: clamp(2rem, 3.8vw, 2.9rem); font-weight: 700; line-height: 1.15; color: var(--text-dark); margin-bottom: 0.8rem; }
.stitle em { font-style: italic; font-weight: 400; color: var(--blue); }
.ssub { font-size: 1rem; color: var(--text-muted); max-width: 560px; margin: 0 auto; line-height: 1.75; }

.projects-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }

.project-card {
  background: var(--off-white); border: 1px solid var(--border);
  border-radius: 16px; overflow: hidden;
  transition: transform 0.3s, box-shadow 0.3s;
}
.project-card:hover { transform: translateY(-4px); box-shadow: 0 16px 48px rgba(59,91,215,0.12); }

/* MOCKUP WINDOW */
.pc-mockup { background: #0d1117; border-bottom: 1px solid rgba(59,91,215,0.2); }
.pm-bar {
  display: flex; align-items: center; gap: 6px;
  padding: 0.65rem 1rem; background: #161b22;
  border-bottom: 1px solid rgba(255,255,255,0.05);
}
.dot { width: 10px; height: 10px; border-radius: 50%; }
.dot.r { background: #ff5f57; }
.dot.y { background: #ffbd2e; }
.dot.g { background: #28c840; }
.pm-tag { margin-left: 0.4rem; font-size: 0.65rem; color: rgba(255,255,255,0.28); font-family: 'SF Mono', monospace; }
.pm-body { padding: 1rem; }

/* POS MOCKUP */
.pm-resto { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; min-height: 200px; }
.pos-cats { display: flex; flex-direction: column; gap: 0.3rem; margin-bottom: 0.75rem; }
.pcat {
  background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07);
  color: rgba(255,255,255,0.4); font-size: 0.65rem; padding: 0.3rem 0.5rem;
  border-radius: 4px; cursor: default; text-align: left;
}
.pcat.active { background: rgba(59,91,215,0.3); border-color: var(--blue); color: rgba(255,255,255,0.85); }
.pos-items { display: flex; flex-direction: column; gap: 0.35rem; }
.pos-item {
  display: flex; justify-content: space-between; align-items: center;
  background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06);
  border-radius: 5px; padding: 0.35rem 0.5rem;
}
.pi-info { display: flex; flex-direction: column; gap: 0.1rem; }
.pi-name { font-size: 0.62rem; color: rgba(255,255,255,0.7); }
.pi-price { font-size: 0.6rem; color: var(--blue-light); font-weight: 600; }
.pi-add { background: var(--blue); color: white; border: none; border-radius: 3px; width: 18px; height: 18px; font-size: 0.7rem; cursor: default; display: flex; align-items: center; justify-content: center; }
.pos-mesa { font-size: 0.65rem; color: rgba(255,255,255,0.4); margin-bottom: 0.5rem; }
.pos-ticket { background: rgba(255,255,255,0.04); border-radius: 5px; padding: 0.5rem; margin-bottom: 0.5rem; }
.pt-row { display: flex; justify-content: space-between; font-size: 0.6rem; color: rgba(255,255,255,0.55); padding: 0.15rem 0; }
.pt-row.total { color: white; font-weight: 700; font-size: 0.65rem; margin-top: 0.2rem; }
.pt-div { height: 1px; background: rgba(255,255,255,0.1); margin: 0.3rem 0; }
.pos-cobrar { width: 100%; background: var(--blue); color: white; border: none; border-radius: 5px; padding: 0.45rem; font-size: 0.65rem; font-weight: 700; cursor: default; }

/* ERP MOCKUP */
.pm-erp { display: grid; grid-template-columns: 80px 1fr; gap: 0; min-height: 200px; }
.erp-sidebar { background: rgba(255,255,255,0.03); border-right: 1px solid rgba(255,255,255,0.05); padding: 0.5rem 0.3rem; }
.es-item { font-size: 0.58rem; color: rgba(255,255,255,0.3); padding: 0.3rem 0.4rem; border-radius: 3px; margin-bottom: 0.2rem; cursor: default; }
.es-item.active { background: rgba(59,91,215,0.3); color: rgba(255,255,255,0.8); }
.es-item.hl { color: #fbbf24; }
.erp-main { padding: 0.75rem; }
.erp-kpis { display: grid; grid-template-columns: repeat(3,1fr); gap: 0.4rem; margin-bottom: 0.75rem; }
.ek { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07); border-radius: 5px; padding: 0.45rem; }
.ek.alert { border-color: rgba(251,191,36,0.3); }
.ek-n { display: block; font-family: 'Syne', sans-serif; font-size: 0.85rem; font-weight: 700; color: white; }
.ek-l { font-size: 0.55rem; color: rgba(255,255,255,0.3); }
.erp-table { }
.et-head { display: grid; grid-template-columns: 1fr 70px 65px; font-size: 0.57rem; color: rgba(255,255,255,0.25); text-transform: uppercase; letter-spacing: 0.06em; padding: 0.25rem 0.3rem; }
.et-row { display: grid; grid-template-columns: 1fr 70px 65px; font-size: 0.62rem; color: rgba(255,255,255,0.6); padding: 0.3rem 0.3rem; border-bottom: 1px solid rgba(255,255,255,0.04); align-items: center; }

/* DASHBOARD MOCKUP */
.pm-dash { min-height: 200px; }
.d-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.7rem; }
.d-title { font-size: 0.65rem; color: rgba(255,255,255,0.45); font-weight: 600; }
.d-filters { display: flex; gap: 0.3rem; }
.df { font-size: 0.58rem; color: rgba(255,255,255,0.3); padding: 0.18rem 0.45rem; border-radius: 100px; cursor: default; }
.df.active { background: rgba(59,91,215,0.3); color: rgba(255,255,255,0.8); }
.d-metrics { display: grid; grid-template-columns: repeat(3,1fr); gap: 0.5rem; margin-bottom: 0.75rem; }
.dm { border-radius: 6px; padding: 0.5rem; border: 1px solid rgba(255,255,255,0.07); }
.dm.green { border-color: rgba(74,222,128,0.2); }
.dm.blue { border-color: rgba(59,91,215,0.3); }
.dm.yellow { border-color: rgba(251,191,36,0.2); }
.dm-n { display: block; font-family: 'Syne', sans-serif; font-size: 0.95rem; font-weight: 700; color: white; }
.dm-l { font-size: 0.55rem; color: rgba(255,255,255,0.3); }
.d-chart { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); border-radius: 6px; padding: 0.6rem; margin-bottom: 0.6rem; }
.dc-label { font-size: 0.58rem; color: rgba(255,255,255,0.3); margin-bottom: 0.4rem; }
.dc-line svg { width: 100%; height: auto; display: block; }
.d-tickets { display: flex; flex-direction: column; gap: 0.3rem; }
.dt-row { display: grid; grid-template-columns: 40px 1fr 65px; align-items: center; gap: 0.4rem; font-size: 0.62rem; color: rgba(255,255,255,0.6); padding: 0.25rem 0; border-bottom: 1px solid rgba(255,255,255,0.04); }
.dt-id { color: var(--blue-light); font-weight: 600; font-size: 0.58rem; }
.dt-desc { overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }

/* BADGE */
.badge-s { display: inline-block; font-size: 0.58rem; font-weight: 600; padding: 0.12rem 0.4rem; border-radius: 100px; white-space: nowrap; }
.badge-s.green { background: rgba(74,222,128,0.15); color: #4ade80; }
.badge-s.yellow { background: rgba(251,191,36,0.15); color: #fbbf24; }
.badge-s.blue { background: rgba(59,91,215,0.2); color: #93a8f4; }
.badge-s.red { background: rgba(248,113,113,0.15); color: #f87171; }

/* INFO SECTION */
.pc-info { padding: 1.8rem; }
.pc-sector { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--blue); margin-bottom: 0.6rem; }
.pc-title { font-family: 'Syne', sans-serif; font-size: 1.05rem; font-weight: 700; color: var(--text-dark); margin-bottom: 1.2rem; line-height: 1.3; }
.pc-case { display: flex; flex-direction: column; gap: 0.9rem; margin-bottom: 1.2rem; }
.case-block { }
.cb-label {
  display: inline-block; font-size: 0.65rem; font-weight: 700;
  letter-spacing: 0.1em; text-transform: uppercase;
  padding: 0.18rem 0.6rem; border-radius: 3px; margin-bottom: 0.4rem;
}
.cb-label.problem { background: rgba(248,113,113,0.1); color: #e05252; }
.cb-label.solution { background: rgba(59,91,215,0.1); color: var(--blue); }
.case-block p { font-size: 0.83rem; color: var(--text-mid); line-height: 1.72; }
.pc-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
.pc-tags span {
  font-size: 0.68rem; font-weight: 500;
  background: var(--blue-ghost); color: var(--blue);
  border: 1px solid rgba(59,91,215,0.15);
  padding: 0.25rem 0.65rem; border-radius: 100px;
}

@media (max-width: 1100px) {
  .projects-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 700px) {
  .projects-grid { grid-template-columns: 1fr; }
}
</style>
