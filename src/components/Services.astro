---
const services = [
  {
    number: "01",
    title: "Sistemas administrativos",
    description:
      "Centralizamos ventas, compras, inventario, clientes, proveedores y reportes en una plataforma diseñada para tu operación.",
    tags: ["#ERP", "#Inventario", "#Operación"],
    image: "Sistemas administrativos",
    imageUrl: "/images/sistema_admin.webp",
    href: "/servicios#sistemas-administrativos",
  },
  {
    number: "02",
    title: "Páginas web y presencia digital",
    description:
      "Diseñamos sitios web profesionales, landing pages y plataformas para negocios que quieren verse confiables y conseguir más clientes.",
    tags: ["#Web", "#SEO", "#Landing pages"],
    image: "Páginas web y presencia digital",
    imageUrl: "/images/paginas_web.webp",
    href: "/servicios#paginas-web",
  },
  {
    number: "03",
    title: "Punto de venta e inventario",
    description:
      "Creamos soluciones para controlar ventas, cortes, productos, existencias, almacenes y sucursales desde un mismo sistema.",
    tags: ["#POS", "#Ventas", "#Stock"],
    image: "Punto de venta e inventario",
    imageUrl: "/images/inventario.webp",
    href: "/servicios#punto-de-venta",
  },
  {
    number: "04",
    title: "Automatización de procesos",
    description:
      "Reducimos tareas repetitivas, errores humanos y tiempo perdido mediante flujos digitales adaptados a tu negocio.",
    tags: ["#Workflows", "#Productividad", "#Procesos"],
    image: "Automatización de procesos",
    imageUrl: "/images/automatizacion.webp",
    href: "/servicios#automatizacion",
  },
  {
    number: "05",
    title: "Dashboards e integraciones",
    description:
      "Conectamos sistemas, APIs, reportes y plataformas para que tengas datos útiles sin depender de archivos dispersos.",
    tags: ["#Dashboards", "#APIs", "#Reportes"],
    image: "Dashboards e integraciones",
    imageUrl: "/images/dashboard.webp",
    href: "/servicios#dashboards-integraciones",
  },
];
---

<section id="expertise" class="services-section source-container">
  <div class="services-heading reveal">
    <span>Servicios</span>

    <h2>Soluciones digitales para operar mejor y vender con más confianza.</h2>
  </div>

  <div class="services-list">
    {
      services.map((service, index) => (
        <article class="service-row stagger-item" style={`--i:${index}`}>
          <div class="service-number">{service.number}</div>

          <div class="service-copy">
            <h3>{service.title}</h3>
            <p>{service.description}</p>

            <div class="tags">
              {service.tags.map((tag) => (
                <span>{tag}</span>
              ))}
            </div>
          </div>

          <a href={service.href} class="learn-link">
            Conocer más ↗
          </a>

          <div
            class="service-image image-slot cut-corner reveal-image"
            style={`background-image: url('${service.imageUrl}')`}
            aria-label={service.image}
          ></div>
        </article>
      ))
    }
  </div>
</section>

<style>
  .services-section {
    border-top: 1px solid var(--line);
  }

  .services-heading {
    display: grid;
    grid-template-columns: 0.28fr 1fr;
    gap: 60px;
    padding: 76px 34px;
    border-left: 1px solid var(--line);
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .services-heading span {
    color: var(--blue);
    font-size: 13px;
    font-weight: 720;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .services-heading h2 {
    max-width: 980px;
    margin: 0;
    font-size: var(--text-section);
    line-height: 1;
    font-weight: 680;
    letter-spacing: -0.065em;
  }

  .service-row {
    display: grid;
    grid-template-columns: 90px 1fr 160px 0.38fr;
    gap: 34px;
    min-height: 300px;
    padding: 30px 34px;
    border-left: 1px solid var(--line);
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    background: transparent;
    transition:
      background 0.35s ease,
      transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .service-row:hover {
    background: rgba(255, 255, 255, 0.46);
    transform: translateY(-4px);
  }

  .service-number {
    color: var(--blue);
    font-size: 24px;
    line-height: 1;
    font-weight: 650;
    letter-spacing: -0.05em;
  }

  .service-copy h3 {
    max-width: 760px;
    margin: 0;
    font-size: var(--text-card);
    line-height: 1;
    font-weight: 680;
    letter-spacing: -0.06em;
  }

  .service-copy p {
    max-width: 820px;
    margin: 18px 0 0;
    color: var(--muted);
    font-size: var(--text-body-lg);
    line-height: 1.42;
    font-weight: 470;
    letter-spacing: -0.025em;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 28px;
  }

  .tags span {
    padding: 8px 10px;
    background: var(--black);
    color: white;
    font-size: 13px;
    line-height: 1;
    font-weight: 600;
  }

  .learn-link {
    align-self: end;
    color: var(--ink);
    font-size: 17px;
    font-weight: 620;
    text-decoration: underline;
    text-underline-offset: 7px;
    transition:
      color 0.25s ease,
      transform 0.25s ease;
  }

  .learn-link:hover {
    color: var(--blue);
    transform: translateY(-2px);
  }

  .service-image {
    min-height: 230px;
  }

  @media (max-width: 1100px) {
    .services-heading,
    .service-row {
      grid-template-columns: 1fr;
    }

    .service-image {
      min-height: 300px;
    }

    .learn-link {
      align-self: start;
    }
  }

  @media (max-width: 700px) {
    .services-heading,
    .service-row {
      padding-left: 20px;
      padding-right: 20px;
    }
  }
</style>
