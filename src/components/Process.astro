---
const steps = [
  {
    num: '01',
    title: 'Descubrimiento',
    desc: 'Analizamos tu negocio, procesos y objetivos. Mapeamos requisitos, integraciones necesarias y flujos antes de escribir una sola línea de código.',
    duration: '1–2 semanass',
    output: 'Brief técnico + Propuesta formal'
  },
  {
    num: '02',
    title: 'Arquitectura y diseño',
    desc: 'Definimos el stack tecnológico, arquitectura de la base de datos y diseñamos los flujos de usuario. Entregamos prototipos antes de desarrollar.',
    duration: '1–2 semanas',
    output: 'Prototipo + Arquitectura documentada'
  },
  {
    num: '03',
    title: 'Desarrollo por sprints',
    desc: 'Iteraciones de 2 semanas con entregas funcionales. Revisiones periódicas contigo para validar que el producto avanza en la dirección correcta.',
    duration: 'Sprints de 2 semanas',
    output: 'Módulos entregados y revisados'
  },
  {
    num: '04',
    title: 'Pruebas y calidad',
    desc: 'Pruebas funcionales, de carga y de seguridad en cada sprint. Revisión de flujos críticos con usuarios reales antes del lanzamiento.',
    duration: 'Continuo en cada sprint',
    output: 'Reporte de QA'
  },
  {
    num: '05',
    title: 'Entrega y puesta en marcha',
    desc: 'Despliegue controlado, migración de datos, capacitación al equipo y soporte en los primeros días de operación para garantizar una transición sin problemas.',
    duration: '1 semana',
    output: 'Sistema en producción + Capacitación'
  },
];
---

<section id="proceso" class="process">
  <div class="container">
    <div class="section-header reveal">
      <div class="stag"><span class="stag-line"></span>Cómo trabajamos</div>
      <h2 class="stitle">Un proceso <em>claro y transparente</em></h2>
      <p class="ssub">Sabemos en todo momento en qué fase está tu proyecto, qué viene después y qué se está entregando.</p>
    </div>

    <div class="steps-list">
      {steps.map((step, i) => (
        <div class="step-row reveal" style={`transition-delay:${i * 0.09}s`}>
          <div class="step-num-col">
            <div class="step-circle">{step.num}</div>
            {i < steps.length - 1 && <div class="step-connector"></div>}
          </div>
          <div class="step-card">
            <div class="step-card-left">
              <h3 class="sc-title">{step.title}</h3>
              <p class="sc-desc">{step.desc}</p>
            </div>
            <div class="step-card-right">
              <div class="sc-meta">
                
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
.process { padding: 7rem 2rem; background: var(--off-white); }
.container { max-width: 1100px; margin: 0 auto; }
.section-header { text-align: center; margin-bottom: 4rem; }
.stag { display: inline-flex; align-items: center; gap: 0.7rem; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--blue); margin-bottom: 1rem; }
.stag-line { display: block; width: 22px; height: 2px; background: var(--blue); border-radius: 1px; }
.stitle { font-family: 'Syne', sans-serif; font-size: clamp(2rem, 3.8vw, 2.9rem); font-weight: 700; line-height: 1.15; color: var(--text-dark); margin-bottom: 0.8rem; }
.stitle em { font-style: italic; font-weight: 400; color: var(--blue); }
.ssub { font-size: 1rem; color: var(--text-muted); max-width: 500px; margin: 0 auto; line-height: 1.75; }

.steps-list { display: flex; flex-direction: column; gap: 0; }

.step-row { display: grid; grid-template-columns: 56px 1fr; gap: 1.5rem; align-items: flex-start; }

.step-num-col { display: flex; flex-direction: column; align-items: center; }
.step-circle {
  width: 48px; height: 48px; border-radius: 50%;
  background: var(--blue); color: white;
  font-family: 'Syne', sans-serif; font-size: 0.8rem; font-weight: 800;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; position: relative; z-index: 1;
  box-shadow: 0 0 0 4px rgba(59,91,215,0.12);
}
.step-connector {
  width: 2px; flex: 1;
  background: linear-gradient(to bottom, var(--blue), rgba(59,91,215,0.15));
  min-height: 40px; margin: 4px 0;
}

.step-card {
  display: grid; grid-template-columns: 1fr auto;
  gap: 2rem; background: white;
  border: 1px solid var(--border); border-radius: 12px;
  padding: 1.8rem 2rem; margin-bottom: 1.5rem;
  box-shadow: 0 2px 16px rgba(59,91,215,0.04);
  transition: box-shadow 0.25s, transform 0.25s;
  align-items: center;
}
.step-card:hover { box-shadow: 0 8px 32px rgba(59,91,215,0.1); transform: translateX(4px); }

.sc-title { font-family: 'Syne', sans-serif; font-size: 1.05rem; font-weight: 700; color: var(--text-dark); margin-bottom: 0.55rem; }
.sc-desc { font-size: 0.88rem; color: var(--text-mid); line-height: 1.75; }

.step-card-right { flex-shrink: 0; }
.sc-meta { display: flex; flex-direction: column; gap: 0.75rem; min-width: 200px; }
.scm-item { display: flex; flex-direction: column; gap: 0.18rem; }
.scm-label { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); }
.scm-val { font-size: 0.82rem; font-weight: 600; color: var(--blue); }

@media (max-width: 768px) {
  .step-card { grid-template-columns: 1fr; gap: 1rem; padding: 1.4rem; }
  .step-row { grid-template-columns: 44px 1fr; gap: 1rem; }
  .step-circle { width: 40px; height: 40px; font-size: 0.72rem; }
  .sc-meta { flex-direction: row; flex-wrap: wrap; }
}
</style>
