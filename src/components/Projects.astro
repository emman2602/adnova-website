---
const projects = [
  {
    sector: "Restaurantes",
    title: "Punto de venta e inventario",
    description:
      "Sistema para gestionar ventas, productos, comandas, cortes e inventario desde una interfaz clara.",
    imageUrl: "/images/restaurante.webp",
    alt: "Sistema de punto de venta e inventario para restaurantes",
    position: "center center"
  },
  {
    sector: "Comercios",
    title: "Control administrativo",
    description:
      "Panel administrativo para visualizar métricas, ventas, inventario, reportes y operación diaria.",
    imageUrl: "/images/administrativo.webp",
    alt: "Dashboard administrativo para comercios y negocios",
    position: "center center"
  },
  {
    sector: "Servicios",
    title: "Página web empresarial",
    description:
      "Sitio web profesional para presentar servicios, generar confianza y facilitar el contacto con clientes.",
    imageUrl: "/images/pagina_empresarial.webp",
    alt: "Página web empresarial profesional para negocios de servicios",
    position: "top center"
  }
];
---

<section id="trabajo" class="work-section source-container reveal">
  <div class="work-heading">
    <span>Proyectos</span>

    <h2>Soluciones que podemos construir.</h2>

    <p>
      Ejemplos visuales de sistemas, plataformas y presencia digital que podemos
      desarrollar para negocios que buscan operar mejor.
    </p>
  </div>

  <div class="work-grid">
    {projects.map((project, index) => (
      <article class="work-card stagger-item" style={`--i:${index}`}>
        <div class="work-image">
          <img
            src={project.imageUrl}
            alt={project.alt}
            loading="lazy"
            decoding="async"
            style={`object-position: ${project.position};`}
          />
        </div>

        <div class="work-content">
          <span>{project.sector}</span>
          <h3>{project.title}</h3>
          <p>{project.description}</p>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .work-section {
    padding: 86px 34px;
    border-left: 1px solid var(--line);
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    background: var(--bg);
  }

  .work-heading {
    display: grid;
    grid-template-columns: 0.58fr 0.42fr;
    gap: 80px;
    align-items: end;
    margin-bottom: 42px;
  }

  .work-heading span {
    grid-column: 1 / -1;
    width: fit-content;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--blue);
    font-size: 12px;
    line-height: 1;
    font-weight: var(--weight-strong);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .work-heading span::before {
    content: "";
    width: 8px;
    height: 8px;
    background: var(--blue);
  }

  .work-heading h2 {
    margin: 0;
    max-width: 920px;
    color: var(--ink);
    font-size: var(--text-section);
    line-height: 1;
    font-weight: var(--weight-heading);
    letter-spacing: -0.065em;
  }

  .work-heading p {
    max-width: 560px;
    margin: 0;
    color: var(--muted);
    font-size: var(--text-body-lg);
    line-height: 1.42;
    font-weight: var(--weight-body);
    letter-spacing: -0.025em;
  }

  .work-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .work-card {
    overflow: hidden;
    background: var(--panel);
    transition:
      transform 0.35s cubic-bezier(0.16, 1, 0.3, 1),
      background 0.35s ease;
  }

  .work-card:hover {
    transform: translateY(-6px);
    background: #ffffff;
  }

  .work-image {
    position: relative;
    height: clamp(270px, 20vw, 390px);
    overflow: hidden;
    background: var(--panel);
    border-bottom: 1px solid var(--line);
  }

  .work-image img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    transition:
      transform 0.6s cubic-bezier(0.16, 1, 0.3, 1),
      filter 0.35s ease;
  }

  .work-card:hover .work-image img {
    transform: scale(1.045);
    filter: contrast(1.04);
  }

  .work-content {
    min-height: 190px;
    display: flex;
    flex-direction: column;
    padding: 24px;
  }

  .work-content span {
    color: var(--blue);
    font-size: 12px;
    line-height: 1;
    font-weight: var(--weight-strong);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .work-content h3 {
    margin: 18px 0 0;
    color: var(--ink);
    font-size: clamp(25px, 2vw, 34px);
    line-height: 0.98;
    font-weight: var(--weight-heading);
    letter-spacing: -0.062em;
  }

  .work-content p {
    margin: 18px 0 0;
    color: var(--muted);
    font-size: 15px;
    line-height: 1.45;
    font-weight: var(--weight-body);
    letter-spacing: -0.02em;
  }

  @media (max-width: 1100px) {
    .work-heading {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .work-grid {
      grid-template-columns: 1fr;
    }

    .work-image {
      height: 430px;
    }
  }

  @media (max-width: 700px) {
    .work-section {
      padding: 70px 20px;
      border-left: 0;
      border-right: 0;
    }

    .work-heading {
      margin-bottom: 34px;
    }

    .work-heading h2 {
      font-size: clamp(34px, 9vw, 48px);
      line-height: 1.02;
    }

    .work-heading p {
      font-size: 17px;
    }

    .work-grid {
      gap: 16px;
    }

    .work-image {
      height: 280px;
    }

    .work-content {
      min-height: auto;
      padding: 22px;
    }

    .work-content h3 {
      font-size: clamp(27px, 8vw, 38px);
    }
  }
</style>