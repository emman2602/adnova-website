<style>
  .container { max-width: 1280px; margin: 0 auto; }
  .stag { display: inline-flex; align-items: center; gap: 0.7rem; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--blue); margin-bottom: 1rem; }
  .stag.light { color: rgba(255,255,255,0.55); }
  .stag-line { display: block; width: 22px; height: 2px; background: var(--blue); border-radius: 1px; }

  .contact {
    padding: 7rem 2rem;
    background: linear-gradient(135deg, var(--blue-deeper) 0%, var(--slate) 100%);
    position: relative; overflow: hidden;
  }
  .contact::before {
    content: ''; position: absolute; top: -180px; right: -180px;
    width: 500px; height: 500px; border-radius: 50%;
    background: radial-gradient(circle, rgba(59,91,215,0.28), transparent 70%);
    pointer-events: none;
  }
  .contact-inner { display: grid; grid-template-columns: 1fr 1.15fr; gap: 5rem; align-items: start; position: relative; z-index: 1; }
  .contact-title { font-family: 'Syne', sans-serif; font-size: clamp(1.9rem, 3.5vw, 2.7rem); font-weight: 700; line-height: 1.15; color: white; margin-bottom: 1rem; }
  .contact-title em { font-style: italic; font-weight: 400; color: var(--blue-pale); }
  .contact-sub { font-size: 0.94rem; color: rgba(255,255,255,0.52); line-height: 1.8; margin-bottom: 2rem; }
  
  .ch-wa {
    display: flex; align-items: center; gap: 0.75rem;
    background: #25D366; color: white;
    padding: 0.9rem 1.5rem; border-radius: 10px;
    font-size: 0.9rem; font-weight: 700; text-decoration: none;
    transition: all 0.22s; width: fit-content;
    box-shadow: 0 4px 16px rgba(37,211,102,0.35);
  }
  .ch-wa:hover { background: #1ebe5d; transform: translateY(-1px); }
  .ch-icon { width: 20px; height: 20px; flex-shrink: 0; }
  .contact-or { font-size: 0.78rem; color: rgba(255,255,255,0.3); text-align: left; margin: 1rem 0; }
  .contact-info-items { display: flex; flex-direction: column; gap: 0.7rem; }
  .cii { display: flex; align-items: center; gap: 0.65rem; }
  .cii svg { width: 16px; height: 16px; flex-shrink: 0; }
  .cii a { font-size: 0.88rem; color: rgba(255,255,255,0.62); text-decoration: none; }
  .cii a:hover { color: white; }

  .contact-form-wrap { background: white; border-radius: 16px; padding: 2.5rem; box-shadow: 0 24px 60px rgba(0,0,0,0.28); }
  .form-title { font-family: 'Syne', sans-serif; font-size: 1.2rem; font-weight: 700; color: var(--text-dark); margin-bottom: 1.5rem; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .form-group { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 0.9rem; }
  .form-group label { font-size: 0.78rem; font-weight: 600; color: var(--text-mid); }
  .form-group input, .form-group select, .form-group textarea {
    border: 1.5px solid var(--border); border-radius: 8px;
    padding: 0.72rem 0.95rem; font-family: 'Outfit', sans-serif;
    font-size: 0.88rem; color: var(--text-dark); outline: none;
  }
  .form-group input:focus { border-color: var(--blue); }
  .form-submit {
    width: 100%; background: var(--blue); color: white; border: none;
    padding: 0.95rem; border-radius: 8px; font-weight: 600; cursor: pointer;
  }
  .form-success { text-align: center; padding: 1rem; background: #ecfdf5; color: #047857; border-radius: 8px; margin-top: 0.75rem; }

  .footer { 
    background: var(--slate); 
    padding: 5rem 2rem 2rem; /* Más aire en la parte superior */
    border-top: 1px solid rgba(255,255,255,0.05);
  }
  .footer-top { 
    display: grid; 
    grid-template-columns: 1fr 2fr;
    gap: 4rem; 
    margin-bottom: 4rem; 
  }
  
  
  .footer-brand { max-width: 320px; }
  .f-logo { display: inline-block; margin-bottom: 1.2rem; text-decoration: none;}
  .f-logo-img { height: 100px; width: auto; object-fit: contain; } 
  .f-logo-text { font-family: 'Syne', sans-serif; font-size: 1.5rem; font-weight: 800; color: white; letter-spacing: 0.05em; }
  
  .brand-desc { 
    font-size: 0.85rem; 
    color: rgba(255,255,255,0.5); 
    line-height: 1.7; 
    margin-bottom: 1.5rem; 
  }
  
  /* Redes Sociales */
  .social-links { display: flex; gap: 1rem; }
  .social-icon { 
    display: flex; align-items: center; justify-content: center;
    width: 36px; height: 36px; 
    background: rgba(255,255,255,0.05); 
    color: rgba(255,255,255,0.6); 
    border-radius: 8px; 
    transition: all 0.25s; 
  }
  .social-icon svg { width: 18px; height: 18px; }
  .social-icon:hover { 
    background: var(--blue); 
    color: white; 
    transform: translateY(-2px); 
  }

  /* Sección de Enlaces */
  .footer-links { 
    display: grid; 
    grid-template-columns: repeat(3, 1fr); 
    gap: 2rem; 
  }
  .fl-group { display: flex; flex-direction: column; gap: 0.8rem; }
  .fl-head { 
    font-size: 0.75rem; 
    font-weight: 700; 
    letter-spacing: 0.12em; 
    text-transform: uppercase; 
    color: white; 
    margin-bottom: 0.5rem; 
  }
  .fl-group a, .fl-text { 
    font-size: 0.85rem; 
    color: rgba(255,255,255,0.5); 
    text-decoration: none; 
    transition: color 0.2s, transform 0.2s; 
    width: fit-content;
  }
  .fl-group a:hover { 
    color: var(--blue-pale); 
    transform: translateX(4px); /* Pequeño salto a la derecha al hacer hover (muy premium) */
  }
  .fl-text.location {
    margin-top: 0.5rem;
    padding-top: 0.5rem;
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  /* Footer Bottom (Legal y Derechos) */
  .footer-bottom { 
    border-top: 1px solid rgba(255,255,255,0.1); 
    padding-top: 2rem; 
    display: flex; 
    justify-content: space-between; 
    align-items: center;
    font-size: 0.8rem; 
    color: rgba(255,255,255,0.4); 
    flex-wrap: wrap; 
    gap: 1rem; 
  }
  .fb-right {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }
  .fb-link { color: rgba(255,255,255,0.4); text-decoration: none; transition: color 0.2s;}
  .fb-link:hover { color: white; text-decoration: underline; }
  .fb-sep { opacity: 0.3; }

  /* Responsivo */
  @media (max-width: 900px) {
    .footer-top { grid-template-columns: 1fr; gap: 3rem; }
    .footer-brand { max-width: 100%; }
    .footer-links { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 500px) {
    .footer-links { grid-template-columns: 1fr; }
    .footer-bottom { flex-direction: column; align-items: flex-start; }
  }

  @media (max-width: 900px) {
    .contact-inner { grid-template-columns: 1fr; gap: 3rem; }
    .form-row { grid-template-columns: 1fr; }
    .footer-inner { flex-direction: column; }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMsg = document.getElementById('form-success') as HTMLElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (submitBtn) { submitBtn.disabled = true; submitBtn.innerText = "Enviando..."; }
    const formData = new FormData(form);
    try {
      const response = await fetch('https://formspree.io/f/xgorqnpy', {
        method: 'POST', body: formData, headers: { 'Accept': 'application/json' }
      });
      if (response.ok) {
        form.style.display = 'none';
        if (successMsg) successMsg.style.display = 'block';
      }
    } catch (error) {
      alert('Error al enviar. Intenta de nuevo.');
      if (submitBtn) { submitBtn.disabled = false; submitBtn.innerText = "Enviar solicitud →"; }
    }
  });
</script>