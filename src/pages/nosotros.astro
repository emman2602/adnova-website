---
import Layout from "../layouts/Layout.astro";
import Contact from "../components/Contact.astro";

const focusAreas = [
  "Sistemas administrativos",
  "Páginas web profesionales",
  "Punto de venta e inventario",
  "Automatización de procesos",
  "Dashboards e integraciones",
];

const workflow = [
  {
    step: "01",
    title: "Entendemos la operación",
    text: "Escuchamos cómo trabaja el negocio, qué procesos se repiten, dónde se pierde tiempo y qué información hace falta para decidir mejor.",
  },
  {
    step: "02",
    title: "Diseñamos una solución útil",
    text: "Definimos flujos, pantallas y prioridades con una visión práctica: que el sistema sea claro, usable y alineado a la forma real de operar.",
  },
  {
    step: "03",
    title: "Construimos y acompañamos",
    text: "Desarrollamos, probamos, ajustamos y acompañamos la puesta en marcha para que la herramienta se integre al trabajo diario.",
  },
];

const differentiators = [
  "Comunicación clara desde el diagnóstico hasta la entrega.",
  "Diseño visual profesional, sobrio y fácil de usar.",
  "Soluciones pensadas para procesos reales, no plantillas genéricas.",
  "Criterio técnico enfocado en estabilidad, escalabilidad y mantenimiento.",
  "Acompañamiento cercano para clientes locales y remotos.",
];

const audiences = [
  "Restaurantes",
  "Tiendas y comercios",
  "Negocios locales",
  "Profesionistas",
  "Empresas de servicios",
  "Emprendimientos",
  "Áreas administrativas",
  "PyMEs en crecimiento",
];
---

<Layout
  title="Nosotros | ADNOVA Software Solutions"
  description="Conoce ADNOVA, empresa de desarrollo de software enfocada en crear soluciones digitales claras, profesionales y adaptadas a negocios reales."
  canonical="https://adnovasoftware.com.mx/nosotros"
>
  <main class="about-page">
    <section class="about-hero page-shell">
      <div class="hero-copy reveal">
        <span class="eyebrow">Nosotros</span>
        <h1>
          Tecnología clara para negocios que quieren operar con más orden.
        </h1>
        <p>
          ADNOVA desarrolla soluciones digitales para empresas y PyMEs que
          necesitan administrar mejor su información, automatizar tareas y crear
          una presencia digital más profesional.
        </p>
      </div>

      <div class="hero-visual reveal-image">
        <img
          src="/images/informacion_general.jpg"
          alt="Laptop con información general sobre una empresa en pantalla"
          width="900"
          height="1000"
          loading="eager"
          decoding="async"
        />

        <div class="floating-note">
          <span>ADNOVA</span>
          <strong>Software para negocios reales</strong>
        </div>
      </div>
    </section>

    <section class="intro-section page-shell">
      <div class="section-index reveal">
        <span>01</span>
        <p>Quiénes somos</p>
      </div>

      <div class="intro-content reveal">
        <h2>
          Somos un equipo enfocado en convertir necesidades operativas en
          herramientas digitales claras.
        </h2>
        <p>
          Nacimos para ayudar a negocios que quieren crecer sin depender de
          hojas dispersas, procesos manuales o sistemas que no se adaptan a su
          realidad. Combinamos diseño, desarrollo y entendimiento de negocio
          para construir plataformas que aporten control, visibilidad y una
          experiencia de uso profesional.
        </p>
      </div>
    </section>

    <section class="split-section dark page-shell">
      <div class="split-copy reveal">
        <span class="eyebrow">02 · Qué hacemos</span>
        <h2>
          Desarrollamos sistemas, sitios web y automatizaciones que resuelven
          problemas concretos.
        </h2>
        <p>
          Trabajamos con soluciones a medida y productos digitales para mejorar
          la operación, ordenar información, agilizar ventas, integrar
          herramientas y fortalecer la presencia digital de cada negocio.
        </p>

        <div class="focus-grid">
          {
            focusAreas.map((item, index) => (
              <span class="stagger-item" style={`--i:${index}`}>
                {item}
              </span>
            ))
          }
        </div>
      </div>

      <div class="split-image reveal-image">
        <img
          src="/images/administrativo.webp"
          alt="Sistema administrativo digital para empresas"
          width="900"
          height="700"
          loading="lazy"
          decoding="async"
        />
      </div>
    </section>

    <section class="workflow-section page-shell">
      <div class="section-index reveal">
        <span>03</span>
        <p>Cómo trabajamos</p>
      </div>

      <div class="workflow-content">
        <h2 class="reveal">
          Primero entendemos, luego diseñamos y finalmente desarrollamos con
          intención.
        </h2>

        <div class="workflow-grid">
          {
            workflow.map((item, index) => (
              <article
                class="workflow-card stagger-item"
                style={`--i:${index}`}
              >
                <span>{item.step}</span>
                <div>
                  <h3>{item.title}</h3>
                  <p>{item.text}</p>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="difference-section page-shell">
      <div class="difference-image reveal-image">
        <img
          src="/images/automatizacion.webp"
          alt="Automatización de procesos para negocios"
          width="900"
          height="900"
          loading="lazy"
          decoding="async"
        />
      </div>

      <div class="difference-copy reveal">
        <span class="eyebrow">04 · Qué nos diferencia</span>
        <h2>
          Cuidamos la claridad, el contexto y la calidad de cada solución.
        </h2>
        <p>
          No buscamos complicar al cliente con tecnología innecesaria. Nuestro
          trabajo consiste en traducir procesos reales en herramientas útiles,
          sostenibles y fáciles de adoptar.
        </p>

        <ul>
          {differentiators.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </section>

    <section class="audience-section page-shell">
      <div class="audience-heading reveal">
        <span class="eyebrow">05 · A quién ayudamos</span>
        <h2>
          Trabajamos con negocios que necesitan más control, orden y presencia
          digital.
        </h2>
      </div>

      <div class="audience-grid">
        {
          audiences.map((item, index) => (
            <span class="stagger-item" style={`--i:${index}`}>
              {item}
            </span>
          ))
        }
      </div>
    </section>

    <section class="vision-section page-shell">
      <div class="vision-panel reveal">
        <span class="eyebrow">06 · Nuestra visión</span>
        <h2>
          Ser un aliado tecnológico para empresas que quieren modernizarse sin
          perder claridad.
        </h2>
        <p>
          Queremos acompañar a negocios en su transformación digital con
          soluciones que puedan crecer con ellos: sistemas mejor estructurados,
          reportes más útiles, procesos automatizados y experiencias digitales
          que transmitan confianza.
        </p>
        <a href="/servicios" class="panel-link">
          Ver servicios
          <strong>↗</strong>
        </a>
      </div>

      <div class="vision-image reveal-image">
        <img
          src="/images/dashboard.webp"
          alt="Dashboard con indicadores para toma de decisiones"
          width="900"
          height="900"
          loading="lazy"
          decoding="async"
        />
      </div>
    </section>

    <section class="closing-section page-shell">
      <div class="closing-copy reveal">
        <span class="eyebrow">07 · Confianza</span>
        <h2>
          Más que desarrollar software, buscamos construir relaciones de
          confianza con los clientes.
        </h2>
        <p>
          Cada proyecto es una oportunidad para simplificar procesos, 
          eliminar barreras y entregar una solución que se sienta auténtica, 
          profesional y preparada para crecer contigo.
        </p>
        <a href="/#contacto" class="closing-button">
          Hablemos de tu proyecto
          <strong>↗</strong>
        </a>
      </div>
    </section>

    <Contact />
  </main>
</Layout>

<style>
  .about-page {
    background: var(--bg);
  }

  .page-shell {
    width: calc(100% - 64px);
    max-width: 1820px;
    margin: 0 auto;
  }

  .about-hero {
    min-height: calc(100vh - 64px);
    display: grid;
    grid-template-columns: 0.58fr 0.42fr;
    border-left: 1px solid var(--line);
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .hero-copy {
    display: grid;
    align-content: end;
    gap: 28px;
    padding: 72px 44px;
    border-right: 1px solid var(--line);
  }

  .eyebrow,
  .section-index span {
    width: fit-content;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--blue);
    font-size: 12px;
    line-height: 1;
    font-weight: var(--weight-strong);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .eyebrow::before,
  .section-index span::before {
    content: "";
    width: 8px;
    height: 8px;
    background: currentColor;
  }

  .hero-copy h1 {
    max-width: 1050px;
    margin: 0;
    color: var(--ink);
    font-size: clamp(44px, 5.6vw, 100px);
    line-height: 0.96;
    font-weight: var(--weight-display);
    letter-spacing: -0.078em;
  }

  .hero-copy p,
  .intro-content p,
  .split-copy p,
  .difference-copy p,
  .vision-panel p,
  .closing-copy p {
    max-width: 760px;
    margin: 0;
    color: var(--muted);
    font-size: var(--text-body-lg);
    line-height: 1.5;
    font-weight: var(--weight-body);
    letter-spacing: -0.02em;
  }

  .hero-visual,
  .split-image,
  .difference-image,
  .vision-image {
    position: relative;
    min-height: 680px;
    overflow: hidden;
    background: var(--panel);
  }

  .hero-visual img,
  .split-image img,
  .difference-image img,
  .vision-image img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .floating-note {
    position: absolute;
    left: 28px;
    right: 28px;
    bottom: 28px;
    display: grid;
    gap: 10px;
    padding: 22px;
    background: rgba(248, 247, 245, 0.86);
    backdrop-filter: blur(16px);
    color: var(--ink);
  }

  .floating-note span {
    color: var(--blue);
    font-size: 12px;
    font-weight: var(--weight-strong);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .floating-note strong {
    max-width: 320px;
    font-size: 26px;
    line-height: 1;
    font-weight: var(--weight-heading);
    letter-spacing: -0.055em;
  }

  .intro-section,
  .workflow-section {
    display: grid;
    grid-template-columns: 0.28fr 0.72fr;
    gap: 86px;
    padding: 96px 34px;
    border-left: 1px solid var(--line);
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .section-index {
    display: grid;
    align-content: start;
    gap: 18px;
  }

  .section-index p {
    max-width: 240px;
    margin: 0;
    color: var(--muted);
    font-size: 15px;
    line-height: 1.4;
  }

  .intro-content h2,
  .workflow-content h2,
  .difference-copy h2,
  .audience-heading h2,
  .vision-panel h2,
  .closing-copy h2 {
    max-width: 1000px;
    margin: 0;
    color: var(--ink);
    font-size: var(--text-section);
    line-height: 1;
    font-weight: var(--weight-heading);
    letter-spacing: -0.065em;
  }

  .intro-content p {
    margin-top: 28px;
  }

  .split-section,
  .difference-section,
  .vision-section {
    display: grid;
    grid-template-columns: 0.52fr 0.48fr;
    min-height: 680px;
    border-left: 1px solid var(--line);
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .split-copy,
  .difference-copy,
  .vision-panel {
    display: grid;
    align-content: center;
    gap: 28px;
    padding: 70px 34px;
  }

  .dark .split-copy {
    background: var(--black);
    color: white;
  }

  .dark .eyebrow,
  .vision-panel .eyebrow,
  .closing-copy .eyebrow {
    color: #c6d5ff;
  }

  .dark h2,
  .closing-copy h2,
  .vision-panel h2 {
    color: white;
  }

  .dark p,
  .closing-copy p,
  .vision-panel p {
    color: rgba(255, 255, 255, 0.7);
  }

  .focus-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 4px;
    margin-top: 10px;
  }

  .focus-grid span,
  .audience-grid span {
    min-height: 88px;
    display: flex;
    align-items: center;
    padding: 0 22px;
    background: var(--panel);
    color: var(--ink);
    font-size: 17px;
    line-height: 1.2;
    font-weight: var(--weight-medium);
    letter-spacing: -0.035em;
  }

  .workflow-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 4px;
    margin-top: 42px;
  }

  .workflow-card {
    min-height: 330px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 26px;
    background: var(--panel);
    transition:
      background 0.25s ease,
      color 0.25s ease,
      transform 0.25s ease;
  }

  .workflow-card:hover,
  .audience-grid span:hover {
    background: var(--black);
    color: white;
    transform: translateY(-4px);
  }

  .workflow-card > span {
    color: var(--blue);
    font-size: 13px;
    font-weight: var(--weight-strong);
    letter-spacing: 0.08em;
  }

  .workflow-card h3 {
    margin: 0;
    color: currentColor;
    font-size: clamp(24px, 2.2vw, 34px);
    line-height: 1;
    letter-spacing: -0.058em;
  }

  .workflow-card p {
    margin: 18px 0 0;
    color: var(--muted);
    font-size: 15px;
    line-height: 1.45;
  }

  .workflow-card:hover p {
    color: rgba(255, 255, 255, 0.72);
  }

  .difference-section {
    grid-template-columns: 0.42fr 0.58fr;
  }

  .difference-image {
    border-right: 1px solid var(--line);
  }

  .difference-copy {
    align-content: end;
  }

  .difference-copy ul {
    display: grid;
    gap: 12px;
    max-width: 760px;
    padding: 0;
    margin: 8px 0 0;
    list-style: none;
  }

  .difference-copy li {
    position: relative;
    padding-left: 22px;
    color: var(--ink);
    font-size: 16px;
    line-height: 1.45;
  }

  .difference-copy li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.62em;
    width: 8px;
    height: 8px;
    background: var(--blue);
  }

  .audience-section {
    display: grid;
    grid-template-columns: 0.48fr 0.52fr;
    gap: 70px;
    padding: 96px 34px;
    border-left: 1px solid var(--line);
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .audience-heading {
    display: grid;
    align-content: start;
    gap: 28px;
  }

  .audience-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 4px;
  }

  .vision-section {
    grid-template-columns: 0.58fr 0.42fr;
  }

  .vision-panel {
    background: var(--blue);
    color: white;
  }

  .panel-link,
  .closing-button {
    width: min(390px, 100%);
    min-height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 8px;
    padding: 0 24px;
    background: white;
    color: var(--blue);
    font-size: 16px;
    font-weight: var(--weight-medium);
    text-decoration: none;
    transition:
      background 0.25s ease,
      transform 0.25s ease;
  }

  .panel-link:hover,
  .closing-button:hover {
    background: #eaf0ff;
    transform: translateY(-2px);
  }

  .panel-link strong,
  .closing-button strong {
    font-size: 28px;
    font-weight: 400;
  }

  .closing-section {
    padding: 100px 34px;
    border-left: 1px solid var(--line);
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    background: var(--black);
    color: white;
  }

  .closing-copy {
    display: grid;
    gap: 28px;
  }

  .closing-button {
    background: var(--blue);
    color: white;
  }

  .closing-button:hover {
    background: var(--blue-dark);
  }

  @media (max-width: 1100px) {
    .about-hero,
    .intro-section,
    .split-section,
    .workflow-section,
    .difference-section,
    .audience-section,
    .vision-section {
      grid-template-columns: 1fr;
    }

    .hero-copy,
    .difference-image {
      border-right: 0;
    }

    .hero-visual,
    .split-image,
    .difference-image,
    .vision-image {
      min-height: 520px;
    }

    .workflow-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 700px) {
    .page-shell {
      width: 100%;
    }

    .about-hero,
    .intro-section,
    .split-section,
    .workflow-section,
    .difference-section,
    .audience-section,
    .vision-section,
    .closing-section {
      border-left: 0;
      border-right: 0;
    }

    .hero-copy,
    .intro-section,
    .workflow-section,
    .audience-section,
    .closing-section {
      padding-left: 20px;
      padding-right: 20px;
    }

    .hero-copy {
      padding-top: 56px;
      padding-bottom: 56px;
    }

    .hero-copy h1 {
      font-size: clamp(40px, 11vw, 64px);
      line-height: 1;
    }

    .hero-visual,
    .split-image,
    .difference-image,
    .vision-image {
      min-height: 420px;
    }

    .intro-section,
    .workflow-section,
    .audience-section,
    .closing-section {
      padding-top: 68px;
      padding-bottom: 68px;
    }

    .split-copy,
    .difference-copy,
    .vision-panel {
      padding: 64px 20px;
    }

    .focus-grid,
    .workflow-grid,
    .audience-grid {
      grid-template-columns: 1fr;
    }

    .workflow-card {
      min-height: 280px;
    }

    .panel-link,
    .closing-button {
      width: 100%;
    }

    .floating-note {
      left: 20px;
      right: 20px;
      bottom: 20px;
    }
  }
</style>
